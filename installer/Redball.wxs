<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">
  <Package Name="Redball"
           Manufacturer="ArMaTeC"
           Version="$(var.ProductVersion)"
           UpgradeCode="A7A9B089-9D1D-4F8A-86DB-6FE89B6F99B0"
           Scope="perUser"
           Compressed="yes"
           InstallerVersion="500">
    
    <!-- Major upgrade with proper scheduling -->
    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed."
                  Schedule="afterInstallExecute"
                  AllowSameVersionUpgrades="no" />
    
    <!-- CAB embedded in MSI for single-file distribution -->
    <MediaTemplate EmbedCab="yes" />

    <!-- Add/Remove Programs metadata -->
    <Property Id="ARPCOMMENTS" Value="Keep-awake utility for Windows with modern WPF UI" />
    <Property Id="ARPURLINFOABOUT" Value="https://github.com/ArMaTeC/Redball" />
    <Property Id="ARPURLUPDATEINFO" Value="https://github.com/ArMaTeC/Redball/releases" />
    <Property Id="ARPHELPLINK" Value="https://github.com/ArMaTeC/Redball/issues" />
    <!-- Enable Repair and Modify for better user control -->
    <Property Id="ARPNOREPAIR" Value="0" />
    <!-- ARPNOMODIFY is set in WixUI extension, remove our override to avoid conflict -->
    <Property Id="ARPSIZE" Value="25000" />
    
    <!-- Add install scope selection (per-user is default) -->
    <Property Id="ALLUSERS" Value="2" />
    <Property Id="MSIINSTALLPERUSER" Value="1" />
    <Property Id="REDBALL_USERDATA_DIR" Secure="yes" />
    <SetProperty Id="REDBALL_USERDATA_DIR" Value="[LocalAppDataFolder]Redball\UserData" After="CostFinalize" Sequence="first" />

    <!-- UserData backup/restore for upgrades -->
    <CustomAction Id="SetBackupDir" Property="REDBALL_BACKUP_DIR" Value="[TempFolder]RedballBackup" />
    
    <CustomAction Id="BackupUserData" 
                  BinaryRef="PowerShellExe"
                  ExeCommand="-ExecutionPolicy Bypass -NoLogo -NoProfile -NonInteractive -WindowStyle Hidden -Command &quot;&amp; { $src='[REDBALL_USERDATA_DIR]'; if (Test-Path $src) { $dst='[REDBALL_BACKUP_DIR]\UserData'; New-Item -ItemType Directory -Path $dst -Force | Out-Null; robocopy $src $dst /E /COPY:DAT /R:2 /W:1 /NFL /NDL /NJH /NJS; if ($LASTEXITCODE -le 7) { exit 0 } else { exit 1 } } }&quot;"
                  Execute="deferred" 
                  Return="check" 
                  Impersonate="yes" />
    
    <CustomAction Id="RestoreUserData"
                  BinaryRef="PowerShellExe"
                  ExeCommand="-ExecutionPolicy Bypass -NoLogo -NoProfile -NonInteractive -WindowStyle Hidden -Command &quot;&amp; { $src='[REDBALL_BACKUP_DIR]\UserData'; $dst='[REDBALL_USERDATA_DIR]'; if (Test-Path $src) { if (-not (Test-Path (Split-Path $dst))) { New-Item -ItemType Directory -Path (Split-Path $dst) -Force | Out-Null }; robocopy $src $dst /E /COPY:DAT /R:2 /W:1 /NFL /NDL /NJH /NJS; if ($LASTEXITCODE -le 7) { Remove-Item -Path '[REDBALL_BACKUP_DIR]' -Recurse -Force -ErrorAction SilentlyContinue; exit 0 } else { exit 1 } } }&quot;"
                  Execute="deferred"
                  Return="check"
                  Impersonate="yes" />
    
    <CustomAction Id="CleanupBackup"
                  BinaryRef="PowerShellExe"
                  ExeCommand="-ExecutionPolicy Bypass -NoLogo -NoProfile -NonInteractive -WindowStyle Hidden -Command &quot;&amp; { if (Test-Path '[REDBALL_BACKUP_DIR]') { Remove-Item -Path '[REDBALL_BACKUP_DIR]' -Recurse -Force -ErrorAction SilentlyContinue } }&quot;"
                  Execute="deferred"
                  Return="ignore"
                  Impersonate="yes" />

    <InstallExecuteSequence>
      <!-- Set backup directory before upgrade -->
      <Custom Action="SetBackupDir" Before="BackupUserData" Condition="UPGRADINGPRODUCTCODE" />
      
      <!-- Backup before upgrade (only when upgrading) -->
      <Custom Action="BackupUserData" Before="RemoveExistingProducts" Condition="UPGRADINGPRODUCTCODE AND REDBALL_BACKUP_DIR" />
      
      <!-- Restore after install (only restore if we actually backed up during this upgrade) -->
      <Custom Action="RestoreUserData" After="InstallFiles" Condition="REDBALL_BACKUP_DIR AND UPGRADINGPRODUCTCODE" />
      
      <!-- Cleanup backup on install finalization (only if we created one during upgrade) -->
      <Custom Action="CleanupBackup" After="InstallFinalize" Condition="REDBALL_BACKUP_DIR AND UPGRADINGPRODUCTCODE" />
    </InstallExecuteSequence>

    <!-- PowerShell executable embedded for custom actions -->
    <Binary Id="PowerShellExe" SourceFile="C:\Windows\System32\WindowsPowerShell\v1.0\powershell.exe" />

    <!-- UI: Use InstallDir dialog set for streamlined experience -->
    <!-- WixUI_InstallDir = Welcome, License, Install Directory, Progress, Exit -->
    <ui:WixUI Id="WixUI_InstallDir" />
    <WixVariable Id="WixUILicenseRtf" Value="Redball-License.rtf" />
    <WixVariable Id="WixUIBannerBmp" Value="banner.bmp" />
    <WixVariable Id="WixUIDialogBmp" Value="dialog.bmp" />
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />
    
    <!-- Customize UI strings for better experience -->
    <!-- Welcome dialog customization -->
    <WixVariable Id="WixUISupportPerUser" Value="1" />
    <WixVariable Id="WixUISupportPerMachine" Value="0" />
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOXTEXT" Value="Launch Redball" />
    <!-- Only check the launch checkbox by default on install (NOT REMOVE) -->
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOX" Value="1">
      <ComponentSearch Id="CheckForInstall" Guid="4B9B1F2A-5B5E-4C3A-95D7-6DBE8468D8E1" />
    </Property>
    <!-- Set checkbox unchecked during uninstall -->
    <SetProperty Id="WIXUI_EXITDIALOGOPTIONALCHECKBOX" Value="0" After="CostFinalize" Condition="REMOVE" />
    
    <!-- Better feature descriptions in UI -->
    <Property Id="WIXUI_FEATURETREE_MAINFEATURE_DESC" Value="Core Redball application with system tray utility, themes, and TypeThing functionality." />
    <Property Id="WIXUI_FEATURETREE_STARTUPFEATURE_DESC" Value="Automatically start Redball when you sign in to Windows." />
    <Property Id="WIXUI_FEATURETREE_CONFIGFEATURE_DESC" Value="Default behavior settings like minimize to tray, battery-aware mode, and idle detection." />
    <Property Id="WIXUI_FEATURETREE_HIDFEATURE_DESC" Value="Attempt to install and activate Interception HID driver on first launch (requires admin approval)." />

    <Icon Id="RedballIcon" SourceFile="Redball.ico" />
    <Property Id="ARPPRODUCTICON" Value="RedballIcon" />



    <!-- .NET 8 prerequisite is handled by the Bundle (Setup.exe) installer.
         If the MSI is run standalone without .NET 8, Windows will show the
         standard .NET runtime-not-found dialog with a direct download link. -->

    <!-- Clear Installed property for proper checkbox behavior on upgrades -->
    <CustomAction Id="ClearInstalled" Property="Installed" Value="" />
    <CustomAction Id="LaunchApplication"
                  FileRef="WPFExecutable"
                  ExeCommand=""
                  Return="asyncNoWait"
                  Impersonate="yes" />
    <InstallUISequence>
      <Custom Action="ClearInstalled" After="ExecuteAction"
              Condition="NOT REMOVE" />
    </InstallUISequence>
    <UI>
      <Publish Dialog="ExitDialog"
               Control="Finish"
               Event="DoAction"
               Value="LaunchApplication"
               Condition="WIXUI_EXITDIALOGOPTIONALCHECKBOX = 1 AND NOT Installed AND NOT REMOVE" />
    </UI>

    <!-- Installation layout -->
    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="INSTALLFOLDER" Name="Redball">
        <Directory Id="AssetsFolder" Name="Assets">
          <Directory Id="AnimationsFolder" Name="Animations" />
        </Directory>
        <Directory Id="DllFolder" Name="dll" />
        <Directory Id="LogsFolder" Name="logs" />
      </Directory>
    </StandardDirectory>


    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="RedballMenuFolder" Name="Redball" />
    </StandardDirectory>

    <StandardDirectory Id="DesktopFolder" />
    <StandardDirectory Id="StartupFolder" />

    <!-- Feature tree gives installer-UI and CLI config support via ADDLOCAL -->
    <Feature Id="MainFeature" Title="Redball Core" Description="Core Redball application files" Level="1" AllowAdvertise="no" Display="expand">
      <ComponentGroupRef Id="CoreComponents" />
      <ComponentGroupRef Id="WPFComponents" />
      <ComponentGroupRef Id="AssetsComponents" />
      <ComponentGroupRef Id="DllComponents" />
      <ComponentGroupRef Id="LogsComponents" />
      <ComponentGroupRef Id="ShortcutComponents" />
      <ComponentGroupRef Id="FileAssociationComponents" />
      
      <!-- Desktop shortcut as optional sub-feature -->
      <Feature Id="DesktopShortcutFeature" Title="Desktop Shortcut" Description="Add shortcut to Desktop" Level="1000" AllowAdvertise="no">
        <ComponentGroupRef Id="DesktopShortcutComponents" />
      </Feature>
    </Feature>

    <Feature Id="StartupFeature" Title="Start with Windows" Description="Launch Redball automatically when Windows starts" Level="1" AllowAdvertise="no">
      <ComponentGroupRef Id="StartupShortcutComponents" />
    </Feature>

    <Feature Id="ConfigFeature" Title="Default Behavior Options" Description="Configure default Redball behavior at install time" Level="1" AllowAdvertise="no" Display="expand">
      <Feature Id="CfgStartMinimized" Title="Start Minimized" Description="Start Redball minimized to system tray" Level="2" AllowAdvertise="no">
        <ComponentGroupRef Id="CfgMinimizedComponents" />
      </Feature>
      <Feature Id="CfgExitOnComplete" Title="Exit on Timer Complete" Description="Automatically exit when timer expires" Level="2" AllowAdvertise="no">
        <ComponentGroupRef Id="CfgExitOnCompleteComponents" />
      </Feature>
      <Feature Id="CfgBatteryAware" Title="Battery-Aware Mode" Description="Pause when running on battery power" Level="2" AllowAdvertise="no">
        <ComponentGroupRef Id="CfgBatteryAwareComponents" />
      </Feature>
      <Feature Id="CfgNetworkAware" Title="Network-Aware Mode" Description="Pause when no network connection detected" Level="2" AllowAdvertise="no">
        <ComponentGroupRef Id="CfgNetworkAwareComponents" />
      </Feature>
      <Feature Id="CfgIdleDetection" Title="Idle Detection" Description="Pause when user is idle" Level="2" AllowAdvertise="no">
        <ComponentGroupRef Id="CfgIdleDetectionComponents" />
      </Feature>
    </Feature>

    <Feature Id="HidFeature" Title="Install HID Driver (No-Restart Attempt)" Description="Attempt to install and activate HID input driver on first launch (requires admin)" Level="2" AllowAdvertise="no">
      <ComponentGroupRef Id="CfgInstallHidDriverNoRestartComponents" />
    </Feature>
  </Package>

  <Fragment>
    <ComponentGroup Id="CoreComponents" Directory="INSTALLFOLDER">
      <Component Id="ReadmeComponent" Guid="CFA8E35A-0DF4-4D9F-8669-7865E96AFB95">
        <File Id="ReadmeFile" Source="..\README.md" KeyPath="yes" />
      </Component>

      <Component Id="LocalesComponent" Guid="E1B2C3D4-5F6A-7B8C-9D0E-1F2A3B4C5D6E">
        <File Id="LocalesFile" Source="..\locales.json" KeyPath="yes" />
      </Component>

      <Component Id="LicenseComponent" Guid="A2B3C4D5-6E7F-8A9B-0C1D-2E3F4A5B6C7D">
        <File Id="LicenseFile" Source="..\LICENSE" KeyPath="yes" />
      </Component>

      <Component Id="ThirdPartyComponent" Guid="F3A4B5C6-7D8E-9F0A-1B2C-3D4E5F6A7B8C">
        <File Id="ThirdPartyFile" Source="..\docs\THIRD-PARTY-NOTICES.md" KeyPath="yes" />
      </Component>

      <Component Id="InstalledMarkerComponent" Guid="4B9B1F2A-5B5E-4C3A-95D7-6DBE8468D8E1">
        <RegistryValue Root="HKCU" Key="Software\Redball" Name="Installed" Type="integer" Value="1" KeyPath="yes" />
        <RegistryValue Root="HKCU" Key="Software\Redball" Name="InstallPath" Type="string" Value="[INSTALLFOLDER]Redball.UI.WPF.exe" />
      </Component>

      <Component Id="UserDataCleanupComponent" Guid="BE2AA645-2AB8-4442-9F64-D8E6F2E9E0A7">
        <RegistryValue Root="HKCU" Key="Software\Redball" Name="UserDataCleanupMarker" Type="integer" Value="1" KeyPath="yes" />
        <util:RemoveFolderEx Property="REDBALL_USERDATA_DIR" On="uninstall" />
      </Component>
    </ComponentGroup>

    <ComponentGroup Id="WPFComponents" Directory="INSTALLFOLDER">
      <Component Id="WPFExeComponent" Guid="C8D5E6F7-8A9B-0C1D-2E3F-4A5B6C7D8E9F">
        <File Id="WPFExecutable" Source="..\dist\wpf-publish\Redball.UI.WPF.exe" KeyPath="yes" />
      </Component>
      <Component Id="WPFDllComponent" Guid="B7C8D9E0-1F2A-3B4C-5D6E-7F8A9B0C1D2E">
        <File Id="WPFMainDll" Source="..\dist\wpf-publish\Redball.UI.WPF.dll" KeyPath="yes" />
      </Component>
      <Component Id="WPFRuntimeConfigComponent" Guid="D9E6F7A8-9B0C-1D2E-3F4A-5B6C7D8E9F0A">
        <File Id="WPFRuntimeConfig" Source="..\dist\wpf-publish\Redball.UI.WPF.runtimeconfig.json" KeyPath="yes" />
      </Component>
      <Component Id="WPFDepsComponent" Guid="E0F1A2B3-C4D5-6E7F-8A9B-0C1D2E3F4A5B">
        <File Id="WPFDeps" Source="..\dist\wpf-publish\Redball.UI.WPF.deps.json" KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <ComponentGroup Id="DllComponents" Directory="DllFolder">
        <Files Include="..\dist\wpf-publish\dll\*.dll" Directory="DllFolder" />
    </ComponentGroup>

    <ComponentGroup Id="LogsComponents" Directory="LogsFolder">
        <Component Id="LogsKeepComponent" Guid="A3B4C5D6-E7F8-A9B0-C1D2-E3F4A5B6C7D8">
            <CreateFolder />
            <File Id="LogsKeepFile" Source="..\dist\wpf-publish\logs\.keep" KeyPath="yes" />
        </Component>
    </ComponentGroup>

    <ComponentGroup Id="AssetsComponents">
      <Component Id="WPFAssetsComponent" Guid="A1B2C3D4-E5F6-7890-ABCD-EF1234567890" Directory="AssetsFolder">
        <File Id="RedballIconAsset" Source="..\dist\wpf-publish\Assets\redball.ico" KeyPath="yes" />
      </Component>
      <Files Include="..\dist\wpf-publish\Assets\Animations\*.json" Directory="AnimationsFolder" />
    </ComponentGroup>

    <ComponentGroup Id="ShortcutComponents" Directory="RedballMenuFolder">
      <Component Id="StartMenuShortcutComponent" Guid="5F6DDFD1-E6C7-4DC7-8E40-3FBC1F0FEAF8">
        <Shortcut Id="StartMenuShortcut"
                  Name="Redball"
                  Description="Launch Redball keep-awake utility"
                  Target="[INSTALLFOLDER]Redball.UI.WPF.exe"
                  WorkingDirectory="INSTALLFOLDER"
                  Icon="RedballIcon" />
        <RemoveFolder Id="RemoveMenuFolder" On="uninstall" />
        <RegistryValue Root="HKCU" Key="Software\Redball" Name="StartMenuShortcut" Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <ComponentGroup Id="DesktopShortcutComponents" Directory="DesktopFolder">
      <Component Id="DesktopShortcutComponent" Guid="91F1505B-3B86-4D0F-953B-C2FB0F4A9A53">
        <Shortcut Id="DesktopShortcut"
                  Name="Redball"
                  Description="Launch Redball keep-awake utility"
                  Target="[INSTALLFOLDER]Redball.UI.WPF.exe"
                  WorkingDirectory="INSTALLFOLDER"
                  Icon="RedballIcon" />
        <RegistryValue Root="HKCU" Key="Software\Redball" Name="DesktopShortcut" Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <ComponentGroup Id="StartupShortcutComponents" Directory="StartupFolder">
      <Component Id="StartupShortcutComponent" Guid="B9E89FA1-62EA-4761-93E2-3A8A0A701B5C">
        <Shortcut Id="StartupShortcut"
                  Name="Redball"
                  Description="Start Redball when Windows signs in"
                  Target="[INSTALLFOLDER]Redball.UI.WPF.exe"
                  WorkingDirectory="INSTALLFOLDER"
                  Icon="RedballIcon" />
        <RegistryValue Root="HKCU" Key="Software\Redball" Name="StartupShortcut" Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <ComponentGroup Id="FileAssociationComponents" Directory="INSTALLFOLDER">
      <Component Id="FileAssociationComponent" Guid="2EBA1ED6-E31D-4B64-B67C-75C12C8A8B88">
        <RegistryKey Root="HKCU" Key="Software\Classes\.redball">
          <RegistryValue Type="string" Value="Redball.Config" KeyPath="yes" />
        </RegistryKey>
        <RegistryKey Root="HKCU" Key="Software\Classes\Redball.Config">
          <RegistryValue Type="string" Value="Redball Configuration File" />
          <RegistryKey Key="shell\open\command">
            <RegistryValue Type="string" Value="&quot;[INSTALLFOLDER]Redball.UI.WPF.exe&quot; -ConfigPath &quot;%1&quot;" />
          </RegistryKey>
        </RegistryKey>
      </Component>
    </ComponentGroup>

    <!-- Installer-selected defaults written to registry (consumed by Redball on startup) -->
    <ComponentGroup Id="CfgMinimizedComponents" Directory="INSTALLFOLDER">
      <Component Id="CfgMinimizedComponent" Guid="5A41D031-69A2-40BE-B2A6-38AE3D04D62D">
        <RegistryValue Root="HKCU" Key="Software\Redball\InstallerDefaults" Name="Minimized" Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <ComponentGroup Id="CfgExitOnCompleteComponents" Directory="INSTALLFOLDER">
      <Component Id="CfgExitOnCompleteComponent" Guid="5A6CEB6D-EA19-4C7E-AF8D-1A2E2E378DE5">
        <RegistryValue Root="HKCU" Key="Software\Redball\InstallerDefaults" Name="ExitOnComplete" Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <ComponentGroup Id="CfgBatteryAwareComponents" Directory="INSTALLFOLDER">
      <Component Id="CfgBatteryAwareComponent" Guid="CD37D16F-F652-4FD9-B541-B89F3076848A">
        <RegistryValue Root="HKCU" Key="Software\Redball\InstallerDefaults" Name="BatteryAware" Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <ComponentGroup Id="CfgNetworkAwareComponents" Directory="INSTALLFOLDER">
      <Component Id="CfgNetworkAwareComponent" Guid="C53D69CF-9370-4A4E-94B4-19662BCA5F17">
        <RegistryValue Root="HKCU" Key="Software\Redball\InstallerDefaults" Name="NetworkAware" Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <ComponentGroup Id="CfgIdleDetectionComponents" Directory="INSTALLFOLDER">
      <Component Id="CfgIdleDetectionComponent" Guid="90CC4352-C1F4-48D1-B60A-99729AF5EA7A">
        <RegistryValue Root="HKCU" Key="Software\Redball\InstallerDefaults" Name="IdleDetection" Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <ComponentGroup Id="CfgInstallHidDriverNoRestartComponents" Directory="INSTALLFOLDER">
      <Component Id="CfgInstallHidDriverNoRestartComponent" Guid="4C9A5F7E-6E8F-4B77-9A2F-3F1D5C2A9E11">
        <RegistryValue Root="HKCU" Key="Software\Redball\InstallerDefaults" Name="InstallHidDriverNoRestart" Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </ComponentGroup>

  </Fragment>
</Wix>
