<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:bal="http://wixtoolset.org/schemas/v4/wxs/bal"
     xmlns:net="http://wixtoolset.org/schemas/v4/wxs/netfx">
  
  <Bundle Name="Redball Setup"
          Manufacturer="ArMaTeC"
          Version="$(var.ProductVersion)"
          UpgradeCode="B8BAC190-AE2E-4F8B-97EC-7FE79C0FA9C1"
          IconSourceFile="Redball.ico"
          AboutUrl="https://github.com/ArMaTeC/Redball">
    
    <BootstrapperApplication>
      <bal:WixStandardBootstrapperApplication
        Theme="hyperlinkLicense"
        LicenseUrl="https://github.com/ArMaTeC/Redball/blob/main/LICENSE"
        LogoFile="redball.png"
        ShowVersion="yes"
        SuppressOptionsUI="no" />
    </BootstrapperApplication>

    <!-- Detect .NET 8 Desktop Runtime x64 -->
    <net:DotNetCoreSearch
      RuntimeType="desktop"
      Platform="x64"
      MajorVersion="8"
      Variable="NET8DesktopInstalled" />

    <Chain>
      <!-- .NET 8 Desktop Runtime x64 - downloaded at build time, not embedded in bundle -->
      <ExePackage
        Id="NetDesktop8Runtime"
        SourceFile="windowsdesktop-runtime-win-x64.exe"
        DownloadUrl="https://aka.ms/dotnet/8.0/windowsdesktop-runtime-win-x64.exe"
        Compressed="no"
        InstallArguments="/install /quiet /norestart"
        RepairArguments="/repair /quiet /norestart"
        UninstallArguments="/uninstall /quiet /norestart"
        DetectCondition="NET8DesktopInstalled"
        InstallCondition="NOT NET8DesktopInstalled"
        Permanent="yes" />

      <!-- Redball MSI -->
      <MsiPackage
        SourceFile="$(var.RedballMsiPath)"
        Compressed="yes"
        Visible="no" />
    </Chain>
    
  </Bundle>
</Wix>
