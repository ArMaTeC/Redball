<?xml version="1.0" encoding="UTF-8"?>
<schemalist>
  <schema id="com.armatec.Redball" path="/com/armatec/Redball/">
    
    <key name="keep-awake-enabled" type="b">
      <default>false</default>
      <summary>Keep awake enabled</summary>
      <description>Whether the keep-awake engine is active</description>
    </key>
    
    <key name="idle-threshold-minutes" type="i">
      <default>5</default>
      <range min="1" max="60"/>
      <summary>Idle threshold</summary>
      <description>Minutes of inactivity before triggering keep-awake</description>
    </key>
    
    <key name="typething-enabled" type="b">
      <default>false</default>
      <summary>TypeThing enabled</summary>
      <description>Enable automatic typing simulation</description>
    </key>
    
    <key name="typething-interval-seconds" type="i">
      <default>300</default>
      <range min="60" max="3600"/>
      <summary>TypeThing interval</summary>
      <description>Seconds between automatic keypresses</description>
    </key>
    
    <key name="battery-aware" type="b">
      <default>true</default>
      <summary>Battery aware mode</summary>
      <description>Disable keep-awake when on battery power</description>
    </key>
    
    <key name="show-notifications" type="b">
      <default>true</default>
      <summary>Show notifications</summary>
      <description>Display desktop notifications for events</description>
    </key>
    
    <key name="mini-widget-enabled" type="b">
      <default>false</default>
      <summary>Mini widget enabled</summary>
      <description>Show a small floating widget with status</description>
    </key>
    
    <key name="autostart" type="b">
      <default>false</default>
      <summary>Autostart on login</summary>
      <description>Start Redball automatically on login</description>
    </key>
    
  </schema>
</schemalist>
