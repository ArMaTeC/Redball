#!/usr/bin/env python3
# Redball launcher script
import sys
import os

# Add the package directory to Python path
pkglibdir = '@PKGLIBDIR@'
sys.path.insert(0, pkglibdir)

# Set environment for localization
os.environ['LOCALEDIR'] = '@LOCALEDIR@'
os.environ['PKGDATADIR'] = '@PKGDATADIR@'

# Import and run
from redball.main import main

if __name__ == '__main__':
    sys.exit(main('@VERSION@'))
