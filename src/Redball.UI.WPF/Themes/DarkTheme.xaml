<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Redball v3.0 Dark Theme
        Fluent Design System with acrylic/glass effects
    -->

    <!-- Background colors -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#01202020"/> <!-- Transparent to allow Mica show through -->
    <SolidColorBrush x:Key="SurfaceBrush" Color="#802D2D2D"/>
    <SolidColorBrush x:Key="CardBrush" Color="#703C3C3C"/>

    <!-- Foreground colors -->
    <SolidColorBrush x:Key="ForegroundBrush" Color="#FFE0E0E0"/>
    <SolidColorBrush x:Key="ForegroundSecondaryBrush" Color="#FFB0B0B0"/>
    <SolidColorBrush x:Key="ForegroundDisabledBrush" Color="#FF808080"/>

    <Color x:Key="AccentColor">#FFDC3545</Color>
    <Color x:Key="AccentDarkColor">#FFB52B3A</Color>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentLightBrush" Color="#FFE34B5C"/>
    <SolidColorBrush x:Key="AccentDarkBrush" Color="{StaticResource AccentDarkColor}"/>

    <!-- State colors -->
    <SolidColorBrush x:Key="ActiveBrush" Color="#FFDC3545"/>
    <SolidColorBrush x:Key="TimedBrush" Color="#FFFD7E14"/>
    <SolidColorBrush x:Key="PausedBrush" Color="#FF6C757D"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="#FF28A745"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#FFFFC107"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="#FFDC3545"/>

    <!-- Border colors -->
    <SolidColorBrush x:Key="BorderBrush" Color="#60404040"/>
    <SolidColorBrush x:Key="BorderLightBrush" Color="#80505050"/>
    <SolidColorBrush x:Key="HoverBrush" Color="#40646464"/>

    <!-- Window and Panel backgrounds -->
    <SolidColorBrush x:Key="WindowBackground" Color="#FF202020"/>
    <SolidColorBrush x:Key="PanelBackground" Color="#A02D2D2D"/>

    <!-- Visual Effects -->
    <DropShadowEffect x:Key="ShadowEffect" BlurRadius="15" ShadowDepth="0" Color="#44000000" Opacity="0.4"/>

</ResourceDictionary>
