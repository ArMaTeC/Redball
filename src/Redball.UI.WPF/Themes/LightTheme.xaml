<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Redball v3.0 Light Theme
        Fluent Design System - Light variant
    -->

    <!-- Background colors -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#FFFAFAFA"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#E0FFFFFF"/>
    <SolidColorBrush x:Key="CardBrush" Color="#D0F5F5F5"/>

    <!-- Foreground colors -->
    <SolidColorBrush x:Key="ForegroundBrush" Color="#FF212529"/>
    <SolidColorBrush x:Key="ForegroundSecondaryBrush" Color="#FF6C757D"/>
    <SolidColorBrush x:Key="ForegroundDisabledBrush" Color="#FFADB5BD"/>

    <Color x:Key="AccentColor">#FFDC3545</Color>
    <Color x:Key="AccentDarkColor">#FFB52B3A</Color>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentLightBrush" Color="#FFE34B5C"/>
    <SolidColorBrush x:Key="AccentDarkBrush" Color="{StaticResource AccentDarkColor}"/>

    <!-- State colors -->
    <SolidColorBrush x:Key="ActiveBrush" Color="#FFDC3545"/>
    <SolidColorBrush x:Key="TimedBrush" Color="#FFFD7E14"/>
    <SolidColorBrush x:Key="PausedBrush" Color="#FF6C757D"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="#FF28A745"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#FFFFC107"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="#FFDC3545"/>

    <!-- Border colors -->
    <SolidColorBrush x:Key="BorderBrush" Color="#70DEE2E6"/>
    <SolidColorBrush x:Key="BorderLightBrush" Color="#90E9ECEF"/>


    <!-- Panel Backgrounds -->
    <SolidColorBrush x:Key="WindowBackground" Color="#FFFAFAFA"/>
    <SolidColorBrush x:Key="PanelBackground" Color="#B0F0F0F0"/>


</ResourceDictionary>
