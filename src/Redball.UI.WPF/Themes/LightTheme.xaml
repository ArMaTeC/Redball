<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Redball v3.0 Light Theme
        Fluent Design System - Light variant
    -->

    <!-- Background colors -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#FFFAFAFA"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="CardBrush" Color="#FFF5F5F5"/>

    <!-- Foreground colors -->
    <SolidColorBrush x:Key="ForegroundBrush" Color="#FF212529"/>
    <SolidColorBrush x:Key="ForegroundSecondaryBrush" Color="#FF6C757D"/>
    <SolidColorBrush x:Key="ForegroundDisabledBrush" Color="#FFADB5BD"/>

    <!-- Accent colors (Redball brand) -->
    <SolidColorBrush x:Key="AccentBrush" Color="#FFDC3545"/>
    <SolidColorBrush x:Key="AccentLightBrush" Color="#FFE34B5C"/>
    <SolidColorBrush x:Key="AccentDarkBrush" Color="#FFB52B3A"/>

    <!-- State colors -->
    <SolidColorBrush x:Key="ActiveBrush" Color="#FFDC3545"/>
    <SolidColorBrush x:Key="TimedBrush" Color="#FFFD7E14"/>
    <SolidColorBrush x:Key="PausedBrush" Color="#FF6C757D"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="#FF28A745"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#FFFFC107"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="#FFDC3545"/>

    <!-- Border colors -->
    <SolidColorBrush x:Key="BorderBrush" Color="#FFDEE2E6"/>
    <SolidColorBrush x:Key="BorderLightBrush" Color="#FFE9ECEF"/>

    <!-- Window and Panel backgrounds -->
    <SolidColorBrush x:Key="WindowBackground" Color="#FFFAFAFA"/>
    <SolidColorBrush x:Key="PanelBackground" Color="#FFF0F0F0"/>

    <!-- Accent color reference for onboarding -->
    <SolidColorBrush x:Key="AccentColor" Color="#FFDC3545"/>


</ResourceDictionary>
