<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Design-time / fallback brushes used by controls and styles.
         ThemeManager still overrides these at runtime. -->

    <!-- Base Colors -->
    <Color x:Key="AccentColor">#FFDC3545</Color>
    <Color x:Key="AccentDarkColor">#FFB52B3A</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#FF202020"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#802D2D2D"/>
    <SolidColorBrush x:Key="CardBrush" Color="#703C3C3C"/>

    <SolidColorBrush x:Key="ForegroundBrush" Color="#FFE0E0E0"/>
    <SolidColorBrush x:Key="ForegroundSecondaryBrush" Color="#FFB0B0B0"/>
    <SolidColorBrush x:Key="ForegroundDisabledBrush" Color="#FF808080"/>

    <SolidColorBrush x:Key="AccentBrush" Color="#FFDC3545"/>
    <SolidColorBrush x:Key="AccentForegroundBrush" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="AccentForegroundSecondaryBrush" Color="#FFE0E0E0"/>
    <SolidColorBrush x:Key="AccentLightBrush" Color="#FFE34B5C"/>
    <SolidColorBrush x:Key="AccentDarkBrush" Color="#FFB52B3A"/>
    <SolidColorBrush x:Key="AccentSurfaceBrush" Color="#80DC3545"/>

    <SolidColorBrush x:Key="BorderBrush" Color="#60606060"/>
    <SolidColorBrush x:Key="BorderLightBrush" Color="#80808080"/>
    <SolidColorBrush x:Key="HoverBrush" Color="#40646464"/>

    <!-- Effects -->
    <DropShadowEffect x:Key="ShadowEffect" BlurRadius="20" ShadowDepth="0" Color="#55000000" Opacity="0.45"/>
    <DropShadowEffect x:Key="DropShadowEffect" BlurRadius="20" ShadowDepth="0" Color="#55000000" Opacity="0.45"/>
</ResourceDictionary>