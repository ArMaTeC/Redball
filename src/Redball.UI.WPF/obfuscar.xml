<?xml version='1.0'?>
<Obfuscator>
  <!-- Input assembly to obfuscate - uses current directory from MSBuild -->
  <Var name="InPath" value="." />
  <Var name="OutPath" value=".\obfuscated" />

  <!-- Main assembly to obfuscate -->
  <Module file="Redball.UI.WPF.dll">
    <!-- Skip types that XAML needs to find by name -->
    <SkipType name="Redball.UI.App" />
    <SkipType name="Redball.UI.Program" />
    
    <!-- Skip ViewModels that may be bound in XAML by name -->
    <SkipNamespace name="Redball.UI.ViewModels" />
    
    <!-- Skip Views that are referenced in XAML -->
    <SkipNamespace name="Redball.UI.Views" />
    
    <!-- Keep public APIs that might be used by external code -->
    <SkipType name="*ViewModel" skipPublic="true" />
    <SkipType name="*View" skipPublic="true" />
    <SkipType name="*Window" skipPublic="true" />
    <SkipType name="*Page" skipPublic="true" />
    <SkipType name="*Control" skipPublic="true" />
  </Module>

  <!-- Also obfuscate Redball.Core.dll -->
  <Module file="..\dll\Redball.Core.dll">
    <!-- Keep public APIs in Core that UI might call -->
    <SkipNamespace name="Redball.Core.Services" skipPublic="true" />
    <SkipNamespace name="Redball.Core.Models" skipPublic="true" />
  </Module>

  <!-- Obfuscation settings -->
  <Var name="KeepPublicApi" value="false" />
  <Var name="HidePrivateApi" value="true" />
  <Var name="RenameProperties" value="true" />
  <Var name="RenameEvents" value="true" />
  <Var name="RenameFields" value="true" />
  <Var name="RenameTypes" value="true" />
  <Var name="RenameMethods" value="true" />
  <Var name="HideStrings" value="true" />
  <Var name="OptimizeMethods" value="true" />
  <Var name="SuppressIldasm" value="true" />

  <!-- Use Unicode renaming for maximum confusion -->
  <Var name="UseUnicodeNames" value="true" />
  <Var name="UseKoreanNames" value="false" />
  <Var name="UseArabicNames" value="false" />

  <!-- String encryption settings -->
  <Var name="StringEncryption" value="true" />
  <Var name="StringEncryptionType" value="internal" />

</Obfuscator>
