<Application x:Class="Redball.UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Redball.UI.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Animation styles (must be loaded before control styles) -->
                <ResourceDictionary Source="/Themes/Animations.xaml"/>
                <!-- Theme dictionaries are loaded dynamically by ThemeManager in App.xaml.cs -->
                <!-- Value Converters -->
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
            <converters:SliderValueToWidthConverter x:Key="SliderValueToWidthConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
