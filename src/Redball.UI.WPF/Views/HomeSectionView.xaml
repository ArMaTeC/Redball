<UserControl x:Class="Redball.UI.Views.HomeSectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock Text="Home" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,8"/>
        <TextBlock Text="Use the main list on the left to switch between Analytics, Product Metrics, Diagnostics, and Settings without opening separate windows."
                   TextWrapping="Wrap"
                   Margin="0,0,0,18"
                   Foreground="{DynamicResource ForegroundSecondaryBrush}"/>

        <UniformGrid Columns="2" Margin="0,0,0,16">
            <Border Style="{DynamicResource CardStyle}" Margin="0,0,8,8">
                <StackPanel>
                    <TextBlock Text="Analytics" FontSize="18" FontWeight="SemiBold"/>
                    <TextBlock Text="View sessions, usage time, and product area activity in this window."
                               Margin="0,8,0,12"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource ForegroundSecondaryBrush}"/>
                    <Button Content="Go to Analytics" Command="{Binding OpenAnalyticsCommand}" Style="{DynamicResource ModernButton}" HorizontalAlignment="Left" ToolTipService.ShowDuration="12000" ToolTip="Open the analytics dashboard section."/>
                </StackPanel>
            </Border>
            <Border Style="{DynamicResource CardStyle}" Margin="8,0,0,8">
                <StackPanel>
                    <TextBlock Text="Product Metrics" FontSize="18" FontWeight="SemiBold"/>
                    <TextBlock Text="Inspect feature adoption and journey outcomes without popups."
                               Margin="0,8,0,12"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource ForegroundSecondaryBrush}"/>
                    <Button Content="Go to Product Metrics" Command="{Binding OpenMetricsCommand}" Style="{DynamicResource ModernButton}" HorizontalAlignment="Left" ToolTipService.ShowDuration="12000" ToolTip="Open the product metrics section."/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <UniformGrid Columns="2">
            <Border Style="{DynamicResource CardStyle}" Margin="0,0,8,8">
                <StackPanel>
                    <TextBlock Text="Diagnostics" FontSize="18" FontWeight="SemiBold"/>
                    <TextBlock Text="Review config, logs, and runtime health in the main shell."
                               Margin="0,8,0,12"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource ForegroundSecondaryBrush}"/>
                    <Button Content="Go to Diagnostics" Command="{Binding OpenDiagnosticsCommand}" Style="{DynamicResource ModernButton}" HorizontalAlignment="Left" ToolTipService.ShowDuration="12000" ToolTip="Open diagnostics and runtime information."/>
                </StackPanel>
            </Border>
            <Border Style="{DynamicResource CardStyle}" Margin="8,0,0,8">
                <StackPanel>
                    <TextBlock Text="Settings" FontSize="18" FontWeight="SemiBold"/>
                    <TextBlock Text="Manage core app behavior from inside the same main window."
                               Margin="0,8,0,12"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource ForegroundSecondaryBrush}"/>
                    <Button Content="Go to Settings" Command="{Binding OpenSettingsCommand}" Style="{DynamicResource PrimaryButton}" HorizontalAlignment="Left" ToolTipService.ShowDuration="12000" ToolTip="Open general Redball settings."/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <UniformGrid Columns="2">
            <Border Style="{DynamicResource CardStyle}" Margin="0,0,8,8">
                <StackPanel>
                    <TextBlock Text="Behavior" FontSize="18" FontWeight="SemiBold"/>
                    <TextBlock Text="Control display sleep prevention, heartbeat mode, and default run duration."
                               Margin="0,8,0,12"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource ForegroundSecondaryBrush}"/>
                    <Button Content="Go to Behavior" Command="{Binding OpenBehaviorCommand}" Style="{DynamicResource ModernButton}" HorizontalAlignment="Left" ToolTipService.ShowDuration="12000" ToolTip="Open behavior settings for display sleep, heartbeat, and duration."/>
                </StackPanel>
            </Border>
            <Border Style="{DynamicResource CardStyle}" Margin="8,0,0,8">
                <StackPanel>
                    <TextBlock Text="Smart Features" FontSize="18" FontWeight="SemiBold"/>
                    <TextBlock Text="Tune battery, network, idle, presentation, and scheduling awareness separately."
                               Margin="0,8,0,12"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource ForegroundSecondaryBrush}"/>
                    <Button Content="Go to Smart Features" Command="{Binding OpenSmartFeaturesCommand}" Style="{DynamicResource ModernButton}" HorizontalAlignment="Left" ToolTipService.ShowDuration="12000" ToolTip="Open battery-aware, network-aware, idle, and schedule settings."/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <UniformGrid Columns="2">
            <Border Style="{DynamicResource CardStyle}" Margin="0,0,8,8">
                <StackPanel>
                    <TextBlock Text="TypeThing" FontSize="18" FontWeight="SemiBold"/>
                    <TextBlock Text="Manage paste-as-typing hotkeys, speed, and typing behavior as its own section."
                               Margin="0,8,0,12"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource ForegroundSecondaryBrush}"/>
                    <Button Content="Go to TypeThing" Command="{Binding OpenTypeThingCommand}" Style="{DynamicResource ModernButton}" HorizontalAlignment="Left" ToolTipService.ShowDuration="12000" ToolTip="Open TypeThing typing automation settings."/>
                </StackPanel>
            </Border>
            <Border Style="{DynamicResource CardStyle}" Margin="8,0,0,8">
                <StackPanel>
                    <TextBlock Text="Updates" FontSize="18" FontWeight="SemiBold"/>
                    <TextBlock Text="Manage update channels and check for new versions separately from application settings."
                               Margin="0,8,0,12"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource ForegroundSecondaryBrush}"/>
                    <Button Content="Go to Updates" Command="{Binding OpenUpdatesCommand}" Style="{DynamicResource ModernButton}" HorizontalAlignment="Left" ToolTipService.ShowDuration="12000" ToolTip="Open update preferences and version controls."/>
                </StackPanel>
            </Border>
        </UniformGrid>
    </StackPanel>
</UserControl>
