<Window x:Class="Redball.UI.Views.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Redball Settings" Height="500" Width="700" MinHeight="400" MinWidth="600" WindowStartupLocation="CenterScreen" Style="{DynamicResource ModernWindow}" Background="{DynamicResource BackgroundBrush}" Foreground="{DynamicResource ForegroundBrush}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40" CornerRadius="8" GlassFrameThickness="0" ResizeBorderThickness="8"/>
    </WindowChrome.WindowChrome>

    <Border Background="{DynamicResource BackgroundBrush}" CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}" CornerRadius="8,8,0,0" Height="50">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                        <TextBlock Text="Settings" FontSize="18" FontWeight="SemiBold"/>
                        <Border x:Name="StatusBadge" CornerRadius="10" Padding="8,2" Margin="12,0,0,0" VerticalAlignment="Center" Background="{DynamicResource AccentBrush}">
                            <TextBlock x:Name="StatusBadgeText" Text="Active" FontSize="11" Foreground="White" FontWeight="Medium"/>
                        </Border>
                    </StackPanel>
                    <Button Content="&#xE711;" FontFamily="Segoe Fluent Icons" FontSize="14" HorizontalAlignment="Right" Margin="0,0,10,0" Style="{DynamicResource CloseButton}" Width="32" Height="32" WindowChrome.IsHitTestVisibleInChrome="True" Click="CloseButton_Click"/>
                </Grid>
            </Border>

            <!-- Content Area -->
            <Grid Grid.Row="1" Margin="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Navigation -->
                <Border Grid.Column="0" Style="{DynamicResource CardStyle}" Margin="0,0,10,0">
                    <StackPanel>
                        <RadioButton x:Name="GeneralTab" Content="General" IsChecked="True" Style="{DynamicResource NavRadioButton}" Checked="Tab_Checked"/>
                        <RadioButton x:Name="BehaviorTab" Content="Behavior" Style="{DynamicResource NavRadioButton}" Checked="Tab_Checked"/>
                        <RadioButton x:Name="FeaturesTab" Content="Features" Style="{DynamicResource NavRadioButton}" Checked="Tab_Checked"/>
                        <RadioButton x:Name="TypeThingTab" Content="TypeThing" Style="{DynamicResource NavRadioButton}" Checked="Tab_Checked"/>
                        <RadioButton x:Name="UpdatesTab" Content="Updates" Style="{DynamicResource NavRadioButton}" Checked="Tab_Checked"/>
                        <RadioButton x:Name="PrivacyTab" Content="Privacy" Style="{DynamicResource NavRadioButton}" Checked="Tab_Checked"/>
                        <RadioButton x:Name="CustomCommandsTab" Content="Palette" Style="{DynamicResource NavRadioButton}" Checked="Tab_Checked"/>
                        <RadioButton x:Name="AboutTab" Content="About" Style="{DynamicResource NavRadioButton}" Checked="Tab_Checked"/>
                    </StackPanel>
                </Border>

                <!-- Tab Content -->
                <Border Grid.Column="1" Style="{DynamicResource CardStyle}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- General Tab -->
                            <StackPanel x:Name="GeneralPanel" Visibility="Visible">
                                <TextBlock Text="General Settings" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>

                                <TextBlock Text="Theme" FontWeight="Medium" Margin="0,0,0,8"/>
                                <ComboBox x:Name="ThemeCombo" Style="{DynamicResource ModernComboBox}" SelectionChanged="ThemeCombo_SelectionChanged">
                                    <ComboBoxItem Content="System Default"/>
                                    <ComboBoxItem IsSelected="True" Content="Dark Mode"/>
                                    <ComboBoxItem Content="Light Mode"/>
                                    <ComboBoxItem Content="Midnight Blue"/>
                                    <ComboBoxItem Content="Forest Green"/>
                                    <ComboBoxItem Content="Ocean Blue"/>
                                    <ComboBoxItem Content="Sunset Orange"/>
                                    <ComboBoxItem Content="Royal Purple"/>
                                    <ComboBoxItem Content="Slate Gray"/>
                                    <ComboBoxItem Content="Rose Gold"/>
                                    <ComboBoxItem Content="Cyberpunk"/>
                                    <ComboBoxItem Content="Coffee"/>
                                    <ComboBoxItem Content="Arctic Frost"/>
                                </ComboBox>

                                <TextBlock Text="Language" FontWeight="Medium" Margin="0,16,0,8"/>
                                <ComboBox x:Name="LanguageCombo" Style="{DynamicResource ModernComboBox}">
                                    <ComboBoxItem IsSelected="True" Content="English"/>
                                    <ComboBoxItem Content="Español"/>
                                    <ComboBoxItem Content="Français"/>
                                    <ComboBoxItem Content="Deutsch"/>
                                </ComboBox>

                                <CheckBox x:Name="MinimizeToTrayCheck" Content="Minimize to tray on start" Margin="0,16,0,8" Style="{DynamicResource ModernCheckBox}"/>
                                <CheckBox x:Name="StartWithWindowsCheck" Content="Start with Windows" Margin="0,0,0,8" Style="{DynamicResource ModernCheckBox}" Checked="StartWithWindowsCheck_Changed" Unchecked="StartWithWindowsCheck_Changed"/>
                                <TextBlock x:Name="StartWithWindowsStatusText" Text="Startup status: Disabled" FontSize="12" Foreground="{DynamicResource ForegroundSecondaryBrush}" Margin="24,0,0,8"/>
                                <CheckBox x:Name="ShowNotificationsCheck" Content="Show notifications" IsChecked="True" Style="{DynamicResource ModernCheckBox}" Checked="ShowNotificationsCheck_Checked" Unchecked="ShowNotificationsCheck_Unchecked"/>

                                <TextBlock x:Name="NotificationModeLabel" Text="Notification Mode" FontWeight="Medium" Margin="0,8,0,8"/>
                                <ComboBox x:Name="NotificationModeCombo" Style="{DynamicResource ModernComboBox}" Margin="0,0,0,8">
                                    <ComboBoxItem IsSelected="True" Content="All events"/>
                                    <ComboBoxItem Content="Important only"/>
                                    <ComboBoxItem Content="Errors only"/>
                                    <ComboBoxItem Content="Silent"/>
                                </ComboBox>

                                <TextBlock Text="Logging" FontSize="16" FontWeight="SemiBold" Margin="0,20,0,16"/>

                                <CheckBox x:Name="VerboseLoggingCheck" Content="Enable verbose logging" Style="{DynamicResource ModernCheckBox}"/>

                                <TextBlock Text="Max Log Size (MB)" FontWeight="Medium" Margin="0,16,0,8"/>
                                <Slider x:Name="MaxLogSizeSlider" Minimum="1" Maximum="100" Value="10" TickFrequency="5" IsSnapToTickEnabled="True" Style="{DynamicResource ModernSlider}" ValueChanged="MaxLogSizeSlider_ValueChanged"/>
                                <TextBlock x:Name="MaxLogSizeText" Text="Max log size: 10 MB" FontSize="12" Margin="0,4,0,12"/>

                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <Button Content="Open Log Folder" Style="{DynamicResource ModernButton}" Margin="0,0,8,0" Click="OpenLogFolderButton_Click"/>
                                    <Button Content="Export Diagnostics" Style="{DynamicResource ModernButton}" Click="ExportDiagnosticsButton_Click"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Behaviour Tab -->
                            <StackPanel x:Name="BehaviorPanel" Visibility="Collapsed">
                                <TextBlock Text="Behaviour Settings" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>

                                <CheckBox x:Name="PreventDisplaySleepCheck" Content="Prevent display sleep" IsChecked="True" Style="{DynamicResource ModernCheckBox}"/>
                                <TextBlock Text="Keep the screen awake while Redball is active" FontSize="12" Foreground="{DynamicResource ForegroundSecondaryBrush}" Margin="24,0,0,16"/>

                                <CheckBox x:Name="UseHeartbeatCheck" Content="Use F15 heartbeat keypress" IsChecked="True" Style="{DynamicResource ModernCheckBox}"/>
                                <TextBlock Text="Send invisible F15 keypress to prevent idle detection" FontSize="12" Foreground="{DynamicResource ForegroundSecondaryBrush}" Margin="24,0,0,16"/>

                                <TextBlock Text="Default Duration (minutes)" FontWeight="Medium" Margin="0,8,0,8"/>
                                <Slider x:Name="DurationSlider" Minimum="1" Maximum="720" Value="60" TickFrequency="30" IsSnapToTickEnabled="True" Style="{DynamicResource ModernSlider}" ValueChanged="DurationSlider_ValueChanged"/>
                                <TextBlock x:Name="DurationText" Text="Duration: 60 minutes" FontSize="12" Margin="0,4,0,0"/>

                                <CheckBox x:Name="AutoExitOnCompleteCheck" Content="Auto-exit after duration completes" Style="{DynamicResource ModernCheckBox}"/>
                            </StackPanel>

                            <!-- Features Tab -->
                            <StackPanel x:Name="FeaturesPanel" Visibility="Collapsed">
                                <TextBlock Text="Smart Features" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>

                                <CheckBox x:Name="BatteryAwareCheck" Content="Battery-aware mode" Style="{DynamicResource ModernCheckBox}"/>
                                <TextBlock Text="Pause when battery is below threshold" FontSize="12" Foreground="{DynamicResource ForegroundSecondaryBrush}" Margin="24,0,0,8"/>
                                <Slider x:Name="BatteryThresholdSlider" Minimum="5" Maximum="50" Value="20" TickFrequency="5" IsSnapToTickEnabled="True" Style="{DynamicResource ModernSlider}" Margin="24,0,0,8" ValueChanged="BatteryThresholdSlider_ValueChanged"/>
                                <TextBlock x:Name="BatteryThresholdText" Text="Threshold: 20%" FontSize="12" Margin="24,0,0,16"/>

                                <CheckBox x:Name="NetworkAwareCheck" Content="Network-aware mode" Style="{DynamicResource ModernCheckBox}"/>
                                <TextBlock Text="Pause when network disconnects" FontSize="12" Foreground="{DynamicResource ForegroundSecondaryBrush}" Margin="24,0,0,16"/>

                                <CheckBox x:Name="IdleDetectionCheck" Content="Idle detection" Style="{DynamicResource ModernCheckBox}"/>
                                <TextBlock Text="Pause when user is idle" FontSize="12" Foreground="{DynamicResource ForegroundSecondaryBrush}" Margin="24,0,0,8"/>
                                <Slider x:Name="IdleThresholdSlider" Minimum="5" Maximum="120" Value="30" TickFrequency="5" IsSnapToTickEnabled="True" Style="{DynamicResource ModernSlider}" Margin="24,0,0,8" ValueChanged="IdleThresholdSlider_ValueChanged"/>
                                <TextBlock x:Name="IdleThresholdText" Text="Threshold: 30 minutes" FontSize="12" Margin="24,0,0,16"/>

                                <CheckBox x:Name="PresentationModeCheck" Content="Presentation mode detection" Style="{DynamicResource ModernCheckBox}"/>
                                <TextBlock Text="Auto-activate during PowerPoint/Teams presentations" FontSize="12" Foreground="{DynamicResource ForegroundSecondaryBrush}" Margin="24,0,0,16"/>

                                <CheckBox x:Name="ScheduledOperationCheck" Content="Scheduled operation" Style="{DynamicResource ModernCheckBox}"/>
                                <TextBlock Text="Active: Weekdays 09:00 - 18:00" FontSize="12" Foreground="{DynamicResource ForegroundSecondaryBrush}" Margin="24,0,0,16"/>
                            </StackPanel>

                            <!-- TypeThing Tab -->
                            <StackPanel x:Name="TypeThingPanel" Visibility="Collapsed">
                                <TextBlock Text="TypeThing (Clipboard Typer)" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>

                                <CheckBox x:Name="EnableTypeThingCheck" Content="Enable TypeThing" IsChecked="True" Style="{DynamicResource ModernCheckBox}"/>

                                <TextBlock Text="Start Hotkey" FontWeight="Medium" Margin="0,16,0,8"/>
                                <TextBox x:Name="StartHotkeyBox" Text="Ctrl+Shift+V" Style="{DynamicResource ModernTextBox}" IsReadOnly="True" PreviewKeyDown="HotkeyBox_PreviewKeyDown" GotFocus="HotkeyBox_GotFocus" LostFocus="HotkeyBox_LostFocus" Cursor="Hand"/>

                                <TextBlock Text="Stop Hotkey" FontWeight="Medium" Margin="0,16,0,8"/>
                                <TextBox x:Name="StopHotkeyBox" Text="Ctrl+Shift+X" Style="{DynamicResource ModernTextBox}" IsReadOnly="True" PreviewKeyDown="HotkeyBox_PreviewKeyDown" GotFocus="HotkeyBox_GotFocus" LostFocus="HotkeyBox_LostFocus" Cursor="Hand"/>

                                <TextBlock Text="Typing Speed" FontWeight="Medium" Margin="0,16,0,8"/>
                                <Slider x:Name="TypingSpeedSlider" Minimum="10" Maximum="500" Value="120" TickFrequency="10" IsSnapToTickEnabled="True" Style="{DynamicResource ModernSlider}" ValueChanged="TypingSpeedSlider_ValueChanged"/>
                                <TextBlock x:Name="TypingSpeedText" Text="Speed: 120 ms per character" FontSize="12" Margin="0,4,0,0"/>

                                <CheckBox x:Name="AddRandomPausesCheck" Content="Add random pauses (human-like typing)" IsChecked="True" Style="{DynamicResource ModernCheckBox}"/>
                                <CheckBox x:Name="TypeNewlinesCheck" Content="Type newlines as Enter key" IsChecked="True" Style="{DynamicResource ModernCheckBox}"/>
                            </StackPanel>

                            <!-- Updates Tab -->
                            <StackPanel x:Name="UpdatesPanel" Visibility="Collapsed">
                                <TextBlock Text="Updates" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>

                                <TextBlock Text="Update Channel" FontWeight="Medium" Margin="0,0,0,8"/>
                                <ComboBox x:Name="UpdateChannelCombo" SelectedIndex="0" Style="{DynamicResource ModernComboBox}">
                                    <ComboBoxItem Content="Stable (Recommended)"/>
                                    <ComboBoxItem Content="Beta"/>
                                    <ComboBoxItem Content="Disabled"/>
                                </ComboBox>

                                <CheckBox x:Name="VerifyUpdateSignatureCheck" Content="Verify update signatures" Margin="0,16,0,8" Style="{DynamicResource ModernCheckBox}"/>
                                <TextBlock Text="Only install signed updates from trusted sources" FontSize="12" Foreground="{DynamicResource ForegroundSecondaryBrush}" Margin="24,0,0,16"/>

                                <Button Content="Check for Updates Now" Style="{DynamicResource PrimaryButton}" Margin="0,16,0,0" HorizontalAlignment="Left" Click="CheckForUpdatesButton_Click"/>

                                <TextBlock x:Name="CurrentVersionText" FontSize="12" Foreground="{DynamicResource ForegroundSecondaryBrush}" Margin="0,16,0,0"/>
                            </StackPanel>

                            <!-- Privacy Tab -->
                            <StackPanel x:Name="PrivacyPanel" Visibility="Collapsed">
                                <TextBlock Text="Privacy &amp; Data" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>

                                <TextBlock Text="Data Encryption" FontWeight="Medium" Margin="0,0,0,8"/>
                                <CheckBox x:Name="EncryptConfigCheck" Content="Encrypt configuration file (DPAPI)" Style="{DynamicResource ModernCheckBox}"/>
                                <TextBlock Text="Encrypts Redball.json using Windows DPAPI (current-user scope)." FontSize="12" Foreground="{DynamicResource ForegroundSecondaryBrush}" Margin="24,0,0,16"/>

                                <TextBlock Text="GDPR Data Export" FontWeight="Medium" Margin="0,8,0,8"/>
                                <TextBlock Text="Export all your data (config, analytics, logs, session state) as a ZIP file for GDPR compliance." FontSize="12" Foreground="{DynamicResource ForegroundSecondaryBrush}" Margin="0,0,0,8" TextWrapping="Wrap"/>
                                <Button Content="Export All My Data" Style="{DynamicResource PrimaryButton}" HorizontalAlignment="Left" Click="ExportAllDataButton_Click"/>
                            </StackPanel>

                            <!-- Palette / Custom Commands Tab -->
                            <StackPanel x:Name="CustomCommandsPanel" Visibility="Collapsed">
                                <TextBlock Text="Command Palette Customization" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <TextBlock Text="Add custom shortcuts to the Ctrl+Shift+P menu." FontSize="12" Foreground="{DynamicResource ForegroundSecondaryBrush}" Margin="0,0,0,16"/>

                                <ItemsControl x:Name="CustomCommandsList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{DynamicResource CardStyle}" Margin="0,0,0,8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                                        <TextBlock Text="{Binding Description}" FontSize="11" Foreground="{DynamicResource ForegroundSecondaryBrush}"/>
                                                    </StackPanel>
                                                    <Button Grid.Column="1" Content="&#xE74D;" FontFamily="Segoe Fluent Icons" Style="{DynamicResource ModernButton}" Width="32" Height="32" Click="RemoveCustomCommand_Click" Tag="{Binding}"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Border Style="{DynamicResource CardStyle}" Margin="0,8,0,0" Background="{DynamicResource SurfaceBrush}">
                                    <StackPanel>
                                        <TextBlock Text="Add New Command" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                        <TextBox x:Name="NewCmdName" Tag="Command Name" Style="{DynamicResource ModernTextBox}" Margin="0,0,0,8"/>
                                        <TextBox x:Name="NewCmdDesc" Tag="Description" Style="{DynamicResource ModernTextBox}" Margin="0,0,0,8"/>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="NewCmdPath" Tag="Path or URL" Style="{DynamicResource ModernTextBox}"/>
                                            <Button Grid.Column="1" Content="..." Style="{DynamicResource ModernButton}" Margin="8,0,0,0" Click="BrowseCommand_Click"/>
                                        </Grid>
                                        <Button Content="Add to Palette" Style="{DynamicResource PrimaryButton}" HorizontalAlignment="Right" Click="AddCustomCommand_Click"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- About Tab -->
                            <StackPanel x:Name="AboutPanel" Visibility="Collapsed">
                                <TextBlock Text="About Redball" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>

                                <Image Source="/Assets/redball.ico" Width="64" Height="64" Margin="0,0,0,16"/>

                                <TextBlock x:Name="AboutVersionText" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>

                                <TextBlock Text="A system tray utility to prevent Windows from going to sleep." TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,16"/>

                                <TextBlock Text="&#xA9; 2026 ArMaTeC" FontSize="12" Foreground="{DynamicResource ForegroundSecondaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                <TextBlock Text="Licensed under MIT License" FontSize="12" Foreground="{DynamicResource ForegroundSecondaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,16"/>

                                <Button Content="View on GitHub" Style="{DynamicResource ModernButton}" HorizontalAlignment="Center" Click="GitHubButton_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- Footer -->
            <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}" CornerRadius="0,0,8,8" Height="60">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="20,0">
                    <Button Content="Cancel" Style="{DynamicResource ModernButton}" Width="80" Margin="0,0,8,0" Click="CancelButton_Click"/>
                    <Button Content="Save" Style="{DynamicResource PrimaryButton}" Width="80" Click="SaveButton_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
