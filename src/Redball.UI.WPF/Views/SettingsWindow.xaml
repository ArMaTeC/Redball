<Window x:Class="Redball.UI.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Redball Settings"
        Height="500" Width="700"
        MinHeight="400" MinWidth="600"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource ModernWindow}"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource ForegroundBrush}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40"
                      CornerRadius="8"
                      GlassFrameThickness="0"
                      ResizeBorderThickness="8"/>
    </WindowChrome.WindowChrome>

    <Border Background="{DynamicResource BackgroundBrush}" CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}" CornerRadius="8,8,0,0" Height="50">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                        <TextBlock Text="Settings" FontSize="18" FontWeight="SemiBold"/>
                        <Border x:Name="StatusBadge" CornerRadius="10" Padding="8,2" Margin="12,0,0,0"
                                VerticalAlignment="Center"
                                Background="{DynamicResource AccentBrush}">
                            <TextBlock x:Name="StatusBadgeText" Text="Active" FontSize="11"
                                      Foreground="White" FontWeight="Medium"/>
                        </Border>
                    </StackPanel>
                    <Button Content="&#xE711;" FontFamily="Segoe Fluent Icons" FontSize="14"
                           HorizontalAlignment="Right" Margin="0,0,10,0"
                           Style="{StaticResource CloseButton}" Width="32" Height="32"
                           WindowChrome.IsHitTestVisibleInChrome="True"
                           Click="CloseButton_Click"/>
                </Grid>
            </Border>

            <!-- Content Area -->
            <Grid Grid.Row="1" Margin="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Navigation -->
                <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,10,0">
                    <StackPanel>
                        <RadioButton x:Name="GeneralTab" Content="General" IsChecked="True"
                                    Style="{StaticResource NavRadioButton}"
                                    Checked="Tab_Checked"/>
                        <RadioButton x:Name="BehaviorTab" Content="Behavior"
                                    Style="{StaticResource NavRadioButton}"
                                    Checked="Tab_Checked"/>
                        <RadioButton x:Name="FeaturesTab" Content="Features"
                                    Style="{StaticResource NavRadioButton}"
                                    Checked="Tab_Checked"/>
                        <RadioButton x:Name="TypeThingTab" Content="TypeThing"
                                    Style="{StaticResource NavRadioButton}"
                                    Checked="Tab_Checked"/>
                        <RadioButton x:Name="UpdatesTab" Content="Updates"
                                    Style="{StaticResource NavRadioButton}"
                                    Checked="Tab_Checked"/>
                        <RadioButton x:Name="AboutTab" Content="About"
                                    Style="{StaticResource NavRadioButton}"
                                    Checked="Tab_Checked"/>
                    </StackPanel>
                </Border>

                <!-- Tab Content -->
                <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- General Tab -->
                            <StackPanel x:Name="GeneralPanel" Visibility="Visible">
                            <TextBlock Text="General Settings" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>

                            <TextBlock Text="Theme" FontWeight="Medium" Margin="0,0,0,8"/>
                            <ComboBox x:Name="ThemeCombo" Style="{StaticResource ModernComboBox}" SelectionChanged="ThemeCombo_SelectionChanged">
                                <ComboBoxItem><TextBlock Text="System Default" Foreground="White"/></ComboBoxItem>
                                <ComboBoxItem IsSelected="True"><TextBlock Text="Dark Mode" Foreground="White"/></ComboBoxItem>
                                <ComboBoxItem><TextBlock Text="Light Mode" Foreground="White"/></ComboBoxItem>
                                <ComboBoxItem><TextBlock Text="Midnight Blue" Foreground="White"/></ComboBoxItem>
                                <ComboBoxItem><TextBlock Text="Forest Green" Foreground="White"/></ComboBoxItem>
                                <ComboBoxItem><TextBlock Text="Ocean Blue" Foreground="White"/></ComboBoxItem>
                                <ComboBoxItem><TextBlock Text="Sunset Orange" Foreground="White"/></ComboBoxItem>
                                <ComboBoxItem><TextBlock Text="Royal Purple" Foreground="White"/></ComboBoxItem>
                                <ComboBoxItem><TextBlock Text="Slate Gray" Foreground="White"/></ComboBoxItem>
                                <ComboBoxItem><TextBlock Text="Rose Gold" Foreground="White"/></ComboBoxItem>
                                <ComboBoxItem><TextBlock Text="Cyberpunk" Foreground="White"/></ComboBoxItem>
                                <ComboBoxItem><TextBlock Text="Coffee" Foreground="White"/></ComboBoxItem>
                                <ComboBoxItem><TextBlock Text="Arctic Frost" Foreground="White"/></ComboBoxItem>
                            </ComboBox>

                            <TextBlock Text="Language" FontWeight="Medium" Margin="0,16,0,8"/>
                            <ComboBox x:Name="LanguageCombo" Style="{StaticResource ModernComboBox}">
                                <ComboBoxItem IsSelected="True"><TextBlock Text="English" Foreground="White"/></ComboBoxItem>
                                <ComboBoxItem><TextBlock Text="Espa&#xF1;ol" Foreground="White"/></ComboBoxItem>
                                <ComboBoxItem><TextBlock Text="Fran&#xE7;ais" Foreground="White"/></ComboBoxItem>
                                <ComboBoxItem><TextBlock Text="Deutsch" Foreground="White"/></ComboBoxItem>
                            </ComboBox>

                            <CheckBox x:Name="MinimizeToTrayCheck" Content="Minimize to tray on start" Margin="0,16,0,8"
                                     Style="{StaticResource ModernCheckBox}"/>
                            <CheckBox x:Name="ShowNotificationsCheck" Content="Show notifications" IsChecked="True"
                                     Style="{StaticResource ModernCheckBox}" Checked="ShowNotificationsCheck_Checked" Unchecked="ShowNotificationsCheck_Unchecked"/>

                            <TextBlock x:Name="NotificationModeLabel" Text="Notification Mode" FontWeight="Medium" Margin="0,8,0,8"/>
                            <ComboBox x:Name="NotificationModeCombo" Style="{StaticResource ModernComboBox}" Margin="0,0,0,8">
                                <ComboBoxItem IsSelected="True"><TextBlock Text="All events" Foreground="White"/></ComboBoxItem>
                                <ComboBoxItem><TextBlock Text="Important only" Foreground="White"/></ComboBoxItem>
                                <ComboBoxItem><TextBlock Text="Errors only" Foreground="White"/></ComboBoxItem>
                                <ComboBoxItem><TextBlock Text="Silent" Foreground="White"/></ComboBoxItem>
                            </ComboBox>
                        </StackPanel>

                        <!-- Behavior Tab -->
                        <StackPanel x:Name="BehaviorPanel" Visibility="Collapsed">
                            <TextBlock Text="Behavior Settings" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>

                            <CheckBox Content="Prevent display sleep" IsChecked="True"
                                     Style="{StaticResource ModernCheckBox}"/>
                            <TextBlock Text="Keep the screen awake while Redball is active" FontSize="12"
                                      Foreground="{DynamicResource ForegroundSecondaryBrush}" Margin="24,0,0,16"/>

                            <CheckBox Content="Use F15 heartbeat keypress" IsChecked="True"
                                     Style="{StaticResource ModernCheckBox}"/>
                            <TextBlock Text="Send invisible F15 keypress to prevent idle detection"
                                      FontSize="12" Foreground="{DynamicResource ForegroundSecondaryBrush}"
                                      Margin="24,0,0,16"/>

                            <TextBlock Text="Default Duration (minutes)" FontWeight="Medium" Margin="0,8,0,8"/>
                            <Slider x:Name="DurationSlider" Minimum="1" Maximum="720" Value="60" TickFrequency="30"
                                   IsSnapToTickEnabled="True" Style="{StaticResource ModernSlider}" ValueChanged="DurationSlider_ValueChanged"/>
                            <TextBlock x:Name="DurationText" Text="Duration: 60 minutes" FontSize="12" Margin="0,4,0,0"/>

                            <CheckBox Content="Auto-exit after duration completes"
                                     Style="{StaticResource ModernCheckBox}"/>
                        </StackPanel>

                        <!-- Features Tab -->
                        <StackPanel x:Name="FeaturesPanel" Visibility="Collapsed">
                            <TextBlock Text="Smart Features" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>

                            <CheckBox x:Name="BatteryAwareCheck" Content="Battery-aware mode" Style="{StaticResource ModernCheckBox}"/>
                            <TextBlock Text="Pause when battery is below threshold"
                                      FontSize="12" Foreground="{DynamicResource ForegroundSecondaryBrush}"
                                      Margin="24,0,0,8"/>
                            <Slider x:Name="BatteryThresholdSlider" Minimum="5" Maximum="50" Value="20" TickFrequency="5"
                                   IsSnapToTickEnabled="True" Style="{StaticResource ModernSlider}" Margin="24,0,0,8" ValueChanged="BatteryThresholdSlider_ValueChanged"/>
                            <TextBlock x:Name="BatteryThresholdText" Text="Threshold: 20%" FontSize="12" Margin="24,0,0,16"/>

                            <CheckBox x:Name="NetworkAwareCheck" Content="Network-aware mode" Style="{StaticResource ModernCheckBox}"/>
                            <TextBlock Text="Pause when network disconnects"
                                      FontSize="12" Foreground="{DynamicResource ForegroundSecondaryBrush}"
                                      Margin="24,0,0,16"/>

                            <CheckBox x:Name="IdleDetectionCheck" Content="Idle detection" Style="{StaticResource ModernCheckBox}"/>
                            <TextBlock Text="Pause when user is idle"
                                      FontSize="12" Foreground="{DynamicResource ForegroundSecondaryBrush}"
                                      Margin="24,0,0,8"/>
                            <Slider x:Name="IdleThresholdSlider" Minimum="5" Maximum="120" Value="30" TickFrequency="5"
                                   IsSnapToTickEnabled="True" Style="{StaticResource ModernSlider}" Margin="24,0,0,8" ValueChanged="IdleThresholdSlider_ValueChanged"/>
                            <TextBlock x:Name="IdleThresholdText" Text="Threshold: 30 minutes" FontSize="12" Margin="24,0,0,16"/>

                            <CheckBox x:Name="PresentationModeCheck" Content="Presentation mode detection" Style="{StaticResource ModernCheckBox}"/>
                            <TextBlock Text="Auto-activate during PowerPoint/Teams presentations"
                                      FontSize="12" Foreground="{DynamicResource ForegroundSecondaryBrush}"
                                      Margin="24,0,0,16"/>

                            <CheckBox x:Name="ScheduledOperationCheck" Content="Scheduled operation" Style="{StaticResource ModernCheckBox}"/>
                            <TextBlock Text="Active: Weekdays 09:00 - 18:00"
                                      FontSize="12" Foreground="{DynamicResource ForegroundSecondaryBrush}"
                                      Margin="24,0,0,16"/>
                        </StackPanel>

                        <!-- TypeThing Tab -->
                        <StackPanel x:Name="TypeThingPanel" Visibility="Collapsed">
                            <TextBlock Text="TypeThing (Clipboard Typer)" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>

                            <CheckBox Content="Enable TypeThing" IsChecked="True" Style="{StaticResource ModernCheckBox}"/>

                            <TextBlock Text="Start Hotkey" FontWeight="Medium" Margin="0,16,0,8"/>
                            <TextBox x:Name="StartHotkeyBox" Text="Ctrl+Shift+V" Style="{StaticResource ModernTextBox}" IsReadOnly="True" PreviewKeyDown="HotkeyBox_PreviewKeyDown" GotFocus="HotkeyBox_GotFocus" LostFocus="HotkeyBox_LostFocus" Cursor="Hand"/>

                            <TextBlock Text="Stop Hotkey" FontWeight="Medium" Margin="0,16,0,8"/>
                            <TextBox x:Name="StopHotkeyBox" Text="Ctrl+Shift+X" Style="{StaticResource ModernTextBox}" IsReadOnly="True" PreviewKeyDown="HotkeyBox_PreviewKeyDown" GotFocus="HotkeyBox_GotFocus" LostFocus="HotkeyBox_LostFocus" Cursor="Hand"/>

                            <TextBlock Text="Typing Speed" FontWeight="Medium" Margin="0,16,0,8"/>
                            <Slider x:Name="TypingSpeedSlider" Minimum="10" Maximum="500" Value="120" TickFrequency="10"
                                   IsSnapToTickEnabled="True" Style="{StaticResource ModernSlider}" ValueChanged="TypingSpeedSlider_ValueChanged"/>
                            <TextBlock x:Name="TypingSpeedText" Text="Speed: 120 ms per character" FontSize="12" Margin="0,4,0,0"/>

                            <CheckBox Content="Add random pauses (human-like typing)" IsChecked="True"
                                     Style="{StaticResource ModernCheckBox}"/>
                            <CheckBox Content="Type newlines as Enter key" IsChecked="True"
                                     Style="{StaticResource ModernCheckBox}"/>
                        </StackPanel>

                        <!-- Updates Tab -->
                        <StackPanel x:Name="UpdatesPanel" Visibility="Collapsed">
                            <TextBlock Text="Updates" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>

                            <TextBlock Text="Update Channel" FontWeight="Medium" Margin="0,0,0,8"/>
                            <ComboBox SelectedIndex="0" Style="{StaticResource ModernComboBox}">
                                <ComboBoxItem><TextBlock Text="Stable (Recommended)" Foreground="White"/></ComboBoxItem>
                                <ComboBoxItem><TextBlock Text="Beta" Foreground="White"/></ComboBoxItem>
                                <ComboBoxItem><TextBlock Text="Disabled" Foreground="White"/></ComboBoxItem>
                            </ComboBox>

                            <CheckBox Content="Verify update signatures" Margin="0,16,0,8"
                                     Style="{StaticResource ModernCheckBox}"/>
                            <TextBlock Text="Only install signed updates from trusted sources"
                                      FontSize="12" Foreground="{DynamicResource ForegroundSecondaryBrush}"
                                      Margin="24,0,0,16"/>

                            <Button Content="Check for Updates Now" Style="{StaticResource PrimaryButton}"
                                   Margin="0,16,0,0" HorizontalAlignment="Left"
                                   Click="CheckForUpdatesButton_Click"/>

                            <TextBlock x:Name="CurrentVersionText" FontSize="12"
                                      Foreground="{DynamicResource ForegroundSecondaryBrush}"
                                      Margin="0,16,0,0"/>
                        </StackPanel>

                        <!-- About Tab -->
                        <StackPanel x:Name="AboutPanel" Visibility="Collapsed">
                            <TextBlock Text="About Redball" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>

                            <Image Source="/Assets/redball.ico" Width="64" Height="64" Margin="0,0,0,16"/>

                            <TextBlock x:Name="AboutVersionText" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>

                            <TextBlock Text="A system tray utility to prevent Windows from going to sleep."
                                      TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,16"/>

                            <TextBlock Text="&#xA9; 2024-2026 ArMaTeC" FontSize="12"
                                      Foreground="{DynamicResource ForegroundSecondaryBrush}"
                                      HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock Text="Licensed under MIT License" FontSize="12"
                                      Foreground="{DynamicResource ForegroundSecondaryBrush}"
                                      HorizontalAlignment="Center" Margin="0,0,0,16"/>

                            <Button Content="View on GitHub" Style="{StaticResource ModernButton}"
                                   HorizontalAlignment="Center" Click="GitHubButton_Click"/>
                        </StackPanel>
                    </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- Footer -->
            <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}" CornerRadius="0,0,8,8" Height="60">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="20,0">
                    <Button Content="Cancel" Style="{StaticResource ModernButton}" Width="80" Margin="0,0,8,0"
                           Click="CancelButton_Click"/>
                    <Button Content="Save" Style="{StaticResource PrimaryButton}" Width="80"
                           Click="SaveButton_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
