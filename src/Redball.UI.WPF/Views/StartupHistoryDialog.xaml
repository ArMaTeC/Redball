<Window x:Class="Redball.UI.WPF.Views.StartupHistoryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Startup History" Height="500" Width="700"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Grid.Row="0" Text="Startup History" FontSize="20" FontWeight="Bold" Margin="10"/>
        
        <ListBox Grid.Row="1" Margin="10" ItemsSource="{Binding}"/>
        
        <Button Grid.Row="2" Content="Close" Click="CloseButton_Click" 
                HorizontalAlignment="Right" Margin="10" Padding="20,5"/>
    </Grid>
</Window>
