<Page x:Class="Redball.UI.WPF.Views.Pages.CrashTelemetryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="600" d:DesignWidth="800"
      Title="Crash Telemetry">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Crash Telemetry &amp; Diagnostics" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>

        <!-- Consent Section -->
        <Border Grid.Row="1" Background="WhiteSmoke" CornerRadius="8" Padding="15" Margin="0,0,0,20">
            <StackPanel>
                <CheckBox x:Name="ConsentCheckBox" Content="Enable crash reporting" FontSize="14"
                          Checked="ConsentCheckBox_Checked" Unchecked="ConsentCheckBox_Unchecked"/>
                <TextBlock Margin="25,5,0,0" Foreground="Gray" FontSize="12" TextWrapping="Wrap">
                    When enabled, anonymous crash reports are sent to help improve reliability.
                    No personal information or keystrokes are ever included.
                </TextBlock>
                <TextBlock x:Name="StatusText" Margin="25,10,0,0" FontSize="12"/>
            </StackPanel>
        </Border>

        <!-- Actions -->
        <StackPanel Grid.Row="2" Margin="0,0,0,20">
            <Button x:Name="ExportDiagnosticsButton" Content="Export Diagnostics Bundle"
                    Click="ExportDiagnosticsButton_Click"
                    Padding="15,10" Margin="0,0,0,10" HorizontalAlignment="Left"/>

            <Button x:Name="ViewRecentCrashesButton" Content="View Recent Crashes"
                    Click="ViewRecentCrashesButton_Click"
                    Padding="15,10" Margin="0,0,0,10" HorizontalAlignment="Left"/>

            <Button x:Name="PurgeOldCrashesButton" Content="Purge Old Crash Reports"
                    Click="PurgeOldCrashesButton_Click"
                    Padding="15,10" HorizontalAlignment="Left"/>
        </StackPanel>

        <!-- Info -->
        <TextBlock Grid.Row="3" Text="Crash reports include: app version, exception type, stack fingerprint (no line numbers), OS version, and feature flags. No PII is collected." Foreground="Gray" FontSize="11" TextWrapping="Wrap"/>
    </Grid>
</Page>
