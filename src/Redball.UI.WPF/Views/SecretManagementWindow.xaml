<Window x:Class="Redball.UI.Views.SecretManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Secure Secret Management" 
        Height="500" Width="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Grid.Row="0" Text="Secure Secret Management" 
                   FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
        
        <DataGrid Grid.Row="1" x:Name="SecretsDataGrid" AutoGenerateColumns="False" 
                  CanUserAddRows="False" IsReadOnly="True" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Secret Key" Binding="{Binding Key}" Width="*"/>
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120"/>
                <DataGridTextColumn Header="Provider" Binding="{Binding Provider}" Width="150"/>
                <DataGridTemplateColumn Header="Actions" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Edit" Click="EditSecret_Click" Tag="{Binding Key}" Margin="2"/>
                                <Button Content="Delete" Click="DeleteSecret_Click" Tag="{Binding Key}" Margin="2"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
        
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10">
            <Button x:Name="AddSecretButton" Content="Add Secret" Click="AddSecret_Click" Padding="15,5" Margin="0,0,10,0"/>
            <Button x:Name="RefreshButton" Content="Refresh" Click="Refresh_Click" Padding="15,5" Margin="0,0,10,0"/>
            <Button x:Name="TestButton" Content="Test Connection" Click="TestConnection_Click" Padding="15,5"/>
        </StackPanel>
        
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="CloseButton" Content="Close" Click="Close_Click" Padding="20,5"/>
        </StackPanel>
    </Grid>
</Window>
