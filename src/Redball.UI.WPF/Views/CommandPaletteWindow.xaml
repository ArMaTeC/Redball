<Window x:Class="Redball.UI.WPF.Views.CommandPaletteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Command Palette"
        Height="450" Width="600"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        KeyDown="Window_KeyDown">

    <Border Background="White" CornerRadius="8" BorderBrush="LightGray" BorderThickness="1" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="5" Opacity="0.3"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Search Box -->
            <Border Grid.Row="0" Background="#f5f5f5" CornerRadius="8,8,0,0" Padding="15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="20" 
                               Foreground="Gray" VerticalAlignment="Center" Margin="0,0,10,0"/>

                    <TextBox x:Name="SearchBox" Grid.Column="1" BorderThickness="0" Background="Transparent"
                             FontSize="16" VerticalContentAlignment="Center"
                             TextChanged="SearchBox_TextChanged" KeyDown="SearchBox_KeyDown"/>

                    <TextBlock Grid.Column="1" x:Name="PlaceholderText" Text="Type a command or search..." 
                               Foreground="Gray" IsHitTestVisible="False" VerticalAlignment="Center"
                               Visibility="{Binding Text.IsEmpty, ElementName=SearchBox, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                    <Button Grid.Column="2" x:Name="CloseButton" Content="&#xE711;" FontFamily="Segoe MDL2 Assets"
                            FontSize="16" BorderThickness="0" Background="Transparent" Padding="5"
                            Click="CloseButton_Click"/>
                </Grid>
            </Border>

            <!-- Category Filter -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="15,5">
                <TextBlock Text="Filter: " Foreground="Gray" VerticalAlignment="Center"/>
                <ComboBox x:Name="CategoryFilter" Width="150" Margin="5,0" SelectionChanged="CategoryFilter_SelectionChanged">
                    <ComboBoxItem Content="All" IsSelected="True"/>
                    <ComboBoxItem Content="Navigation"/>
                    <ComboBoxItem Content="Actions"/>
                    <ComboBoxItem Content="Features"/>
                    <ComboBoxItem Content="Diagnostics"/>
                </ComboBox>
            </StackPanel>

            <!-- Results List -->
            <ListBox x:Name="ResultsList" Grid.Row="2" BorderThickness="0" Background="Transparent"
                     MouseDoubleClick="ResultsList_MouseDoubleClick" SelectionChanged="ResultsList_SelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="35"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="{Binding IconGlyph}" FontFamily="Segoe MDL2 Assets"
                                       FontSize="20" VerticalAlignment="Center" Foreground="#333"/>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Subtitle}" FontSize="11" Foreground="Gray"/>
                            </StackPanel>

                            <TextBlock Grid.Column="2" Text="{Binding Shortcut}" FontSize="11" Foreground="Gray"
                                       VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Footer -->
            <Border Grid.Row="3" Background="#f5f5f5" CornerRadius="0,0,8,8" Padding="10">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE752;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="Gray" Margin="0,0,5,0"/>
                    <TextBlock Text="Enter to execute" FontSize="11" Foreground="Gray" Margin="0,0,15,0"/>
                    <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="Gray" Margin="0,0,5,0"/>
                    <TextBlock Text="Up/Down to navigate" FontSize="11" Foreground="Gray" Margin="0,0,15,0"/>
                    <TextBlock Text="Esc to close" FontSize="11" Foreground="Gray"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
