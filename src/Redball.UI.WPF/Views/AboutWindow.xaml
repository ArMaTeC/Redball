<Window x:Class="Redball.UI.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About Redball"
        Height="400" Width="500"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource ModernWindow}"
        Background="{StaticResource BackgroundBrush}"
        ResizeMode="NoResize">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40"
                      CornerRadius="8"
                      GlassFrameThickness="0"
                      ResizeBorderThickness="0"/>
    </WindowChrome.WindowChrome>

    <Border Background="{StaticResource BackgroundBrush}" CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" CornerRadius="8,8,0,0" Height="50">
                <Grid>
                    <TextBlock Text="About" FontSize="18" FontWeight="SemiBold"
                              VerticalAlignment="Center" Margin="20,0"/>
                    <Button Content="&#xE711;" FontFamily="Segoe Fluent Icons" FontSize="14"
                           HorizontalAlignment="Right" Margin="0,0,10,0"
                           Style="{StaticResource ModernButton}" Width="32" Height="32"
                           Click="CloseButton_Click"/>
                </Grid>
            </Border>

            <!-- Content -->
            <StackPanel Grid.Row="1" Margin="40,30" HorizontalAlignment="Center">
                <!-- Icon Placeholder -->
                <Border Width="80" Height="80" Background="{StaticResource AccentBrush}"
                       CornerRadius="40" Margin="0,0,0,20">
                    <TextBlock Text="RB" FontSize="32" FontWeight="Bold" Foreground="White"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <TextBlock Text="Redball v3.0.0" FontSize="24" FontWeight="Bold"
                          HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <TextBlock Text="Modern WPF Edition" FontSize="14"
                          Foreground="{StaticResource AccentBrush}"
                          HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <TextBlock Text="A system tray utility to prevent Windows from going to sleep."
                          TextWrapping="Wrap" TextAlignment="Center"
                          Foreground="{StaticResource ForegroundBrush}"
                          Margin="0,0,0,20"/>

                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,20">
                    <TextBlock Text="&#xA9; 2024-2026 GCI Network Solutions"
                              FontSize="12" Foreground="{StaticResource ForegroundSecondaryBrush}"/>
                    <TextBlock Text="Licensed under MIT License"
                              FontSize="12" Foreground="{StaticResource ForegroundSecondaryBrush}"/>
                </StackPanel>

                <Button Content="View on GitHub" Style="{StaticResource ModernButton}"
                       Width="140" Click="GitHubButton_Click"/>
            </StackPanel>

            <!-- Footer -->
            <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" CornerRadius="0,0,8,8" Height="50">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="Check for Updates" Style="{StaticResource ModernButton}"
                           Click="UpdateButton_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
