<UserControl x:Class="Redball.UI.Views.TypeThingSectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lottie="clr-namespace:LottieSharp.WPF;assembly=LottieSharp">
    <StackPanel>
        <Grid Margin="0,0,0,16">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="TypeThing" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBlock Text="TypeThing types clipboard contents as keystrokes." 
                           TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource ForegroundSecondaryBrush}"/>
            </StackPanel>
            <lottie:LottieAnimationView x:Name="TypeThingLottie" Width="64" Height="48" 
                                       FileName="Assets/Animations/typething_launch.json" 
                                       AutoPlay="{Binding IsTypeThingActive}" 
                                       RepeatCount="-1" 
                                       HorizontalAlignment="Right" VerticalAlignment="Center"/>
        </Grid>
        
        <Border Style="{DynamicResource CardStyle}">
            <StackPanel>
                <CheckBox x:Name="TypeThingEnabledCheck" Content="Enable TypeThing" Style="{DynamicResource ModernCheckBox}" Margin="0,0,0,8"/>
                <TextBlock Text="Start Hotkey" FontWeight="Medium" Margin="0,8,0,8"/>
                <TextBox x:Name="TypeThingStartHotkeyBox" Style="{DynamicResource ModernTextBox}" Margin="0,0,0,8"/>
                <TextBlock Text="Stop Hotkey" FontWeight="Medium" Margin="0,8,0,8"/>
                <TextBox x:Name="TypeThingStopHotkeyBox" Style="{DynamicResource ModernTextBox}" Margin="0,0,0,8"/>
                <TextBlock Text="Typing Speed (ms per char)" FontWeight="Medium" Margin="0,8,0,8"/>
                <Slider x:Name="TypingSpeedSlider" Minimum="10" Maximum="500" Value="120" Style="{DynamicResource ModernSlider}"/>
                <CheckBox x:Name="TypeThingAddRandomPausesCheck" Content="Add random pauses (human-like typing)" Style="{DynamicResource ModernCheckBox}" Margin="0,12,0,8"/>
                <CheckBox x:Name="TypeThingTypeNewlinesCheck" Content="Type newlines as Enter key" Style="{DynamicResource ModernCheckBox}" Margin="0,0,0,8"/>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
