<UserControl x:Class="Redball.UI.Views.PomodoroSectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock Text="Pomodoro" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <TextBlock Text="The Pomodoro Technique helps you stay focused by working in timed intervals. Redball keeps your PC awake during focus sessions and can optionally pause during breaks." 
                   TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource ForegroundSecondaryBrush}" Margin="0,0,0,16"/>
        
        <Border Style="{DynamicResource CardStyle}">
            <StackPanel>
                <CheckBox x:Name="PomodoroEnabledCheck" Content="Enable Pomodoro timer" Style="{DynamicResource ModernCheckBox}" Margin="0,0,0,8"/>
                <TextBlock Text="Focus Duration (minutes)" FontWeight="Medium" Margin="0,8,0,8"/>
                <Slider x:Name="PomodoroFocusSlider" Minimum="1" Maximum="60" Value="25" Style="{DynamicResource ModernSlider}" Margin="0,0,0,8"/>
                <TextBlock x:Name="PomodoroFocusText" Text="25 minutes" FontSize="12" Margin="0,0,0,16"/>
                <TextBlock Text="Break Duration (minutes)" FontWeight="Medium" Margin="0,8,0,8"/>
                <Slider x:Name="PomodoroBreakSlider" Minimum="1" Maximum="30" Value="5" Style="{DynamicResource ModernSlider}" Margin="0,0,0,8"/>
                <TextBlock x:Name="PomodoroBreakText" Text="5 minutes" FontSize="12" Margin="0,0,0,16"/>
                <TextBlock Text="Long Break Duration (minutes)" FontWeight="Medium" Margin="0,8,0,8"/>
                <Slider x:Name="PomodoroLongBreakSlider" Minimum="1" Maximum="60" Value="15" Style="{DynamicResource ModernSlider}" Margin="0,0,0,8"/>
                <TextBlock x:Name="PomodoroLongBreakText" Text="15 minutes" FontSize="12" Margin="0,0,0,16"/>
                <TextBlock Text="Long Break Interval (sessions)" FontWeight="Medium" Margin="0,8,0,8"/>
                <Slider x:Name="PomodoroIntervalSlider" Minimum="1" Maximum="10" Value="4" Style="{DynamicResource ModernSlider}" Margin="0,0,0,8"/>
                <TextBlock x:Name="PomodoroIntervalText" Text="Every 4 sessions" FontSize="12" Margin="0,0,0,0"/>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
