<Window x:Class="Redball.UI.Views.UpdateCheckProgressWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Checking for Updates" Width="420" Height="240" ResizeMode="NoResize" WindowStartupLocation="CenterOwner" WindowStyle="ToolWindow" Background="#FF1E1E1E" Foreground="#FFCCCCCC" FontFamily="Segoe UI, Arial" FontSize="13">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="&#xE895; Checking for Updates" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="20" Foreground="#FF4FC3F7" Margin="0,0,0,15"/>

        <!-- Status Text -->
        <TextBlock Grid.Row="1" x:Name="StatusText" Text="Connecting to update server..." TextWrapping="Wrap" Foreground="#FFFFFFFF" Margin="0,0,0,10"/>

        <!-- Progress Bar -->
        <ProgressBar Grid.Row="2" x:Name="ProgressBar" Height="20" Minimum="0" Maximum="100" Value="0" IsIndeterminate="True" Background="#FF2D2D2D" Foreground="#FF4FC3F7" BorderThickness="0"/>

        <!-- Stage Indicators -->
        <Grid Grid.Row="3" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Bottom">
                <Ellipse x:Name="Stage1" Width="8" Height="8" Fill="#FF666666" Margin="0,0,4,0"/>
                <Ellipse x:Name="Stage2" Width="8" Height="8" Fill="#FF666666" Margin="0,0,4,0"/>
                <Ellipse x:Name="Stage3" Width="8" Height="8" Fill="#FF666666" Margin="0,0,4,0"/>
                <Ellipse x:Name="Stage4" Width="8" Height="8" Fill="#FF666666" Margin="0,0,4,0"/>
                <Ellipse x:Name="Stage5" Width="8" Height="8" Fill="#FF666666"/>
            </StackPanel>

            <TextBlock Grid.Column="1" x:Name="StageLabel" Text="Connecting..." HorizontalAlignment="Right" VerticalAlignment="Bottom" Foreground="#FF888888" FontSize="11"/>
        </Grid>
    </Grid>
</Window>
