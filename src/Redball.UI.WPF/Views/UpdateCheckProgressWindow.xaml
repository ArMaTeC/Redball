<Window x:Class="Redball.UI.Views.UpdateCheckProgressWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Checking for Updates" Width="420" Height="240" ResizeMode="NoResize" WindowStartupLocation="CenterOwner" WindowStyle="ToolWindow" Background="{DynamicResource BackgroundBrush}" Foreground="{DynamicResource ForegroundBrush}" FontFamily="Segoe UI, Arial" FontSize="13">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header with icon + text -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="&#xE895;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="20" Foreground="{DynamicResource AccentBrush}" Margin="0,0,8,0"/>
            <TextBlock Text="Checking for Updates" FontSize="20" Foreground="{DynamicResource ForegroundBrush}" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Status Text -->
        <TextBlock Grid.Row="1" x:Name="StatusText" Text="Connecting to update server..." TextWrapping="Wrap" Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,5"/>

        <!-- Current File (for file hashing stage) -->
        <TextBlock Grid.Row="2" x:Name="CurrentFileText" Text="" TextWrapping="Wrap" Foreground="{DynamicResource ForegroundSecondaryBrush}" FontSize="11" Margin="0,0,0,10" Visibility="Collapsed"/>

        <!-- Progress Bar -->
        <ProgressBar Grid.Row="3" x:Name="ProgressBar" Height="20" Minimum="0" Maximum="100" Value="0" IsIndeterminate="True" Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource AccentBrush}" BorderThickness="0"/>

        <!-- Stage Indicators -->
        <Grid Grid.Row="4" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Bottom">
                <Ellipse x:Name="Stage1" Width="8" Height="8" Fill="{DynamicResource ForegroundDisabledBrush}" Margin="0,0,4,0"/>
                <Ellipse x:Name="Stage2" Width="8" Height="8" Fill="{DynamicResource ForegroundDisabledBrush}" Margin="0,0,4,0"/>
                <Ellipse x:Name="Stage3" Width="8" Height="8" Fill="{DynamicResource ForegroundDisabledBrush}" Margin="0,0,4,0"/>
                <Ellipse x:Name="Stage4" Width="8" Height="8" Fill="{DynamicResource ForegroundDisabledBrush}" Margin="0,0,4,0"/>
                <Ellipse x:Name="Stage5" Width="8" Height="8" Fill="{DynamicResource ForegroundDisabledBrush}"/>
            </StackPanel>

            <TextBlock Grid.Column="1" x:Name="StageLabel" Text="Connecting..." HorizontalAlignment="Right" VerticalAlignment="Bottom" Foreground="{DynamicResource ForegroundSecondaryBrush}" FontSize="11"/>
        </Grid>
    </Grid>
</Window>
