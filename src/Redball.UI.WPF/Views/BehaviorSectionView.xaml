<UserControl x:Class="Redball.UI.Views.BehaviorSectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock Text="Behavior" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <TextBlock Text="Control how Redball keeps your PC awake. Set the default session duration, choose which invisible function key to send as a heartbeat, and configure timed or scheduled keep-awake sessions." 
                   TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource ForegroundSecondaryBrush}" Margin="0,0,0,16"/>
        
        <Border Style="{DynamicResource CardStyle}">
            <StackPanel>
                <CheckBox x:Name="PreventDisplaySleepCheck" Content="Prevent display sleep" Style="{DynamicResource ModernCheckBox}" Margin="0,0,0,8"/>
                <TextBlock Text="Heartbeat Input" FontWeight="Medium" Margin="0,8,0,8"/>
                <ComboBox x:Name="HeartbeatInputModeCombo" Style="{DynamicResource ModernComboBox}" Margin="0,0,0,12">
                    <ComboBoxItem Content="Disabled"/>
                    <ComboBoxItem Content="F13"/>
                    <ComboBoxItem Content="F14"/>
                    <ComboBoxItem Content="F15"/>
                    <ComboBoxItem Content="F16"/>
                </ComboBox>
                <TextBlock Text="Default Duration (minutes)" FontWeight="Medium" Margin="0,8,0,8"/>
                <Slider x:Name="DurationSlider" Minimum="1" Maximum="720" Value="60" Style="{DynamicResource ModernSlider}"/>
                <CheckBox x:Name="AutoExitOnCompleteCheck" Content="Auto-exit after duration completes" Style="{DynamicResource ModernCheckBox}" Margin="0,12,0,12"/>
                <CheckBox x:Name="PowerPlanAutoSwitchCheck" Content="Switch to High Performance when active" Style="{DynamicResource ModernCheckBox}" Margin="0,0,0,4"/>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
