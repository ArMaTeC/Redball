<Window x:Class="Redball.UI.Views.DiagnosticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Redball Diagnostics"
        Height="560" Width="760"
        MinHeight="480" MinWidth="680"
        WindowStartupLocation="CenterScreen"
        Style="{DynamicResource ModernWindow}"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource ForegroundBrush}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40"
                      CornerRadius="8"
                      GlassFrameThickness="0"
                      ResizeBorderThickness="8"/>
    </WindowChrome.WindowChrome>

    <Border Background="{DynamicResource BackgroundBrush}" CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}" CornerRadius="8,8,0,0" Height="50">
                <Grid>
                    <TextBlock Text="Diagnostics" FontSize="18" FontWeight="SemiBold"
                              VerticalAlignment="Center" Margin="20,0"/>
                    <Button Content="&#xE711;" FontFamily="Segoe Fluent Icons" FontSize="14"
                           HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0"
                           Style="{DynamicResource CloseButton}" Width="32" Height="32"
                           Click="CloseButton_Click"/>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20">
                    <UniformGrid Columns="2" Margin="0,0,0,16">
                        <Border Style="{DynamicResource CardStyle}" Margin="0,0,8,8">
                            <StackPanel>
                                <TextBlock Text="Configuration" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                <TextBlock x:Name="ConfigPathText" Margin="0,0,0,6" TextWrapping="Wrap"/>
                                <TextBlock x:Name="ValidationStatusText" Margin="0,0,0,6" TextWrapping="Wrap"/>
                                <TextBlock x:Name="DirtyStateText" Margin="0,0,0,6" TextWrapping="Wrap"/>
                                <TextBlock x:Name="UpdateStatusText" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{DynamicResource CardStyle}" Margin="8,0,0,8">
                            <StackPanel>
                                <TextBlock Text="Logging" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                <TextBlock x:Name="LogPathText" Margin="0,0,0,6" TextWrapping="Wrap"/>
                                <TextBlock x:Name="LogDirectoryText" Margin="0,0,0,6" TextWrapping="Wrap"/>
                                <TextBlock x:Name="LogLevelText" Margin="0,0,0,6" TextWrapping="Wrap"/>
                                <TextBlock x:Name="LogSizeText" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <UniformGrid Columns="2" Margin="0,0,0,16">
                        <Border Style="{DynamicResource CardStyle}" Margin="0,0,8,8">
                            <StackPanel>
                                <TextBlock Text="Runtime" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                <TextBlock x:Name="KeepAwakeStatusText" Margin="0,0,0,6" TextWrapping="Wrap"/>
                                <TextBlock x:Name="HeartbeatText" Margin="0,0,0,6" TextWrapping="Wrap"/>
                                <TextBlock x:Name="MonitorStatusText" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{DynamicResource CardStyle}" Margin="8,0,0,8">
                            <StackPanel>
                                <TextBlock Text="Analytics" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                <TextBlock x:Name="AnalyticsEnabledText" Margin="0,0,0,6" TextWrapping="Wrap"/>
                                <TextBlock x:Name="AnalyticsSessionsText" Margin="0,0,0,6" TextWrapping="Wrap"/>
                                <TextBlock x:Name="AnalyticsFeaturesText" Margin="0,0,0,6" TextWrapping="Wrap"/>
                                <TextBlock x:Name="AnalyticsPathText" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <UniformGrid Columns="2" Margin="0,0,0,16">
                        <Border Style="{DynamicResource CardStyle}" Margin="0,0,8,8">
                            <StackPanel>
                                <TextBlock Text="Memory Health" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                <TextBlock x:Name="WorkingSetText" Margin="0,0,0,6" TextWrapping="Wrap"/>
                                <TextBlock x:Name="GcTotalText" Margin="0,0,0,6" TextWrapping="Wrap"/>
                                <TextBlock x:Name="GcGen0Text" Margin="0,0,0,6" TextWrapping="Wrap"/>
                                <TextBlock x:Name="GcGen1Text" Margin="0,0,0,6" TextWrapping="Wrap"/>
                                <TextBlock x:Name="GcGen2Text" Margin="0,0,0,6" TextWrapping="Wrap"/>
                                <TextBlock x:Name="MemoryTrendText" Margin="0,0,0,6" TextWrapping="Wrap" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{DynamicResource CardStyle}" Margin="8,0,0,8">
                            <StackPanel>
                                <TextBlock Text="Memory Samples" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                <TextBox x:Name="MemorySamplesText"
                                         IsReadOnly="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         AcceptsReturn="True"
                                         Height="120"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <UniformGrid Columns="2" Margin="0,0,0,16">
                        <Border Style="{DynamicResource CardStyle}" Margin="0,0,8,8">
                            <StackPanel>
                                <TextBlock Text="Validation Issues" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                <TextBox x:Name="ValidationIssuesText"
                                         IsReadOnly="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         AcceptsReturn="True"
                                         Height="120"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{DynamicResource CardStyle}" Margin="8,0,0,8">
                            <StackPanel>
                                <TextBlock Text="Update Health" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                <TextBlock x:Name="UpdateChannelText" Margin="0,0,0,6" TextWrapping="Wrap"/>
                                <TextBlock x:Name="UpdateRepoText" Margin="0,0,0,6" TextWrapping="Wrap"/>
                                <TextBlock x:Name="UpdateVerificationText" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <Border Style="{DynamicResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Recent Log Output" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12"/>
                            <TextBox x:Name="RecentLogText"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     AcceptsReturn="True"
                                     Height="220"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}" CornerRadius="0,0,8,8" Height="60">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="20,0">
                    <Button Content="Refresh" Style="{DynamicResource ModernButton}" Margin="0,0,8,0" Click="RefreshButton_Click"/>
                    <Button Content="Copy All" Style="{DynamicResource ModernButton}" Margin="0,0,8,0" Click="CopyAllButton_Click" ToolTip="Copy all diagnostic info to clipboard"/>
                    <Button Content="Open Config" Style="{DynamicResource ModernButton}" Margin="0,0,8,0" Click="OpenConfigButton_Click"/>
                    <Button Content="Open Analytics" Style="{DynamicResource ModernButton}" Margin="0,0,8,0" Click="OpenAnalyticsButton_Click"/>
                    <Button Content="Export Config" Style="{DynamicResource ModernButton}" Margin="0,0,8,0" Click="ExportConfigButton_Click"/>
                    <Button Content="Open Log Folder" Style="{DynamicResource ModernButton}" Margin="0,0,8,0" Click="OpenLogFolderButton_Click"/>
                    <Button Content="Export Diagnostics" Style="{DynamicResource PrimaryButton}" Click="ExportDiagnosticsButton_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
