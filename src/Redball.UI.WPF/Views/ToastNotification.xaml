<UserControl x:Class="Redball.UI.Views.ToastNotification"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="360" MinHeight="80" MaxHeight="200">
    <Border Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Effect="{StaticResource DropShadowEffect}">
        <Border.Resources>
            <DropShadowEffect x:Key="DropShadowEffect" BlurRadius="16" ShadowDepth="4" Opacity="0.3" Color="Black"/>
        </Border.Resources>
        <Grid Margin="16,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Icon -->
            <TextBlock x:Name="IconText" Grid.Column="0" Grid.RowSpan="2"
                       FontFamily="Segoe Fluent Icons" FontSize="24"
                       VerticalAlignment="Center" Margin="0,0,12,0"
                       Foreground="{DynamicResource AccentBrush}"/>

            <!-- Title -->
            <TextBlock x:Name="TitleText" Grid.Column="1" Grid.Row="0"
                       FontWeight="SemiBold" FontSize="13"
                       Foreground="{DynamicResource ForegroundBrush}"
                       TextTrimming="CharacterEllipsis"/>

            <!-- Close button -->
            <Button Grid.Column="2" Grid.Row="0"
                    Content="&#xE711;" FontFamily="Segoe Fluent Icons" FontSize="10"
                    Background="Transparent" BorderThickness="0"
                    Foreground="{DynamicResource ForegroundSecondaryBrush}"
                    Width="20" Height="20" Padding="0"
                    VerticalAlignment="Top" HorizontalAlignment="Right"
                    Click="CloseButton_Click" Cursor="Hand"/>

            <!-- Message -->
            <TextBlock x:Name="MessageText" Grid.Column="1" Grid.Row="1" Grid.ColumnSpan="2"
                       FontSize="12" TextWrapping="Wrap"
                       Foreground="{DynamicResource ForegroundSecondaryBrush}"
                       Margin="0,4,0,0"/>
        </Grid>
    </Border>
</UserControl>
