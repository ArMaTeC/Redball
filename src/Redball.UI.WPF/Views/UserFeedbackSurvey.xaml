<Window x:Class="Redball.UI.Views.UserFeedbackSurvey"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Send Feedback" 
        Height="550" 
        Width="500"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackground}">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" 
                Background="{DynamicResource AccentColor}" 
                Height="60"
                Padding="20,0">
            <TextBlock Text="📝 Send Feedback" 
                       FontSize="20" 
                       FontWeight="SemiBold"
                       Foreground="White"
                       VerticalAlignment="Center"/>
        </Border>
        
        <!-- Form -->
        <ScrollViewer Grid.Row="1" Margin="20,15">
            <StackPanel>
                <TextBlock Text="How satisfied are you with Redball?" 
                           FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10"/>
                
                <!-- Rating Stars -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                    <Button x:Name="Star1" Content="☆" FontSize="32" Click="Star_Click" Tag="1" 
                            Background="Transparent" BorderThickness="0" Foreground="{DynamicResource AccentColor}"/>
                    <Button x:Name="Star2" Content="☆" FontSize="32" Click="Star_Click" Tag="2" 
                            Background="Transparent" BorderThickness="0" Foreground="{DynamicResource AccentColor}"/>
                    <Button x:Name="Star3" Content="☆" FontSize="32" Click="Star_Click" Tag="3" 
                            Background="Transparent" BorderThickness="0" Foreground="{DynamicResource AccentColor}"/>
                    <Button x:Name="Star4" Content="☆" FontSize="32" Click="Star_Click" Tag="4" 
                            Background="Transparent" BorderThickness="0" Foreground="{DynamicResource AccentColor}"/>
                    <Button x:Name="Star5" Content="☆" FontSize="32" Click="Star_Click" Tag="5" 
                            Background="Transparent" BorderThickness="0" Foreground="{DynamicResource AccentColor}"/>
                </StackPanel>
                
                <TextBlock x:Name="RatingLabel" Text="Click a star to rate" 
                           HorizontalAlignment="Center" Opacity="0.6" Margin="0,0,0,20"/>
                
                <!-- Feature Feedback -->
                <TextBlock Text="Which features do you use most?" 
                           FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10"/>
                
                <CheckBox x:Name="KeepAwakeCheck" Content="Keep-Awake toggle" Margin="0,5"/>
                <CheckBox x:Name="TimerCheck" Content="Timed sessions" Margin="0,5"/>
                <CheckBox x:Name="BatteryCheck" Content="Battery-aware mode" Margin="0,5"/>
                <CheckBox x:Name="NetworkCheck" Content="Network-aware mode" Margin="0,5"/>
                <CheckBox x:Name="ScheduleCheck" Content="Scheduled operation" Margin="0,5"/>
                <CheckBox x:Name="TypeThingCheck" Content="TypeThing clipboard typer" Margin="0,5"/>
                
                <TextBlock Text="What would you like to see improved?" 
                           FontSize="14" FontWeight="SemiBold" Margin="0,20,0,10"/>
                
                <TextBox x:Name="FeedbackText" 
                         Height="100" 
                         TextWrapping="Wrap" 
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         Padding="10"/>
                
                <CheckBox x:Name="ContactCheck" Content="I may be contacted about this feedback" 
                          Margin="0,15,0,0"/>
                
                <TextBox x:Name="EmailText" 
                         Margin="0,5,0,0" 
                         Padding="8"
                         IsEnabled="False"
                         ToolTip="Optional: Leave your email if you'd like us to follow up"/>
            </StackPanel>
        </ScrollViewer>
        
        <!-- Footer -->
        <Border Grid.Row="2" 
                Background="{DynamicResource PanelBackground}" 
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="20,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" 
                           Text="Feedback helps us improve!" 
                           VerticalAlignment="Center"
                           Opacity="0.6"/>
                
                <Button Grid.Column="1" 
                        x:Name="CancelButton"
                        Content="Cancel" 
                        Click="CancelButton_Click"
                        Margin="0,0,10,0"
                        Padding="20,8"/>
                
                <Button Grid.Column="2" 
                        x:Name="SubmitButton"
                        Content="Send Feedback" 
                        Click="SubmitButton_Click"
                        Padding="20,8"
                        Background="{DynamicResource AccentColor}"
                        Foreground="White"
                        FontWeight="SemiBold"/>
            </Grid>
        </Border>
    </Grid>
</Window>
