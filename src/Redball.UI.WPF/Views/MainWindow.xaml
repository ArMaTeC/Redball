<Window x:Class="Redball.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        xmlns:vm="clr-namespace:Redball.UI.ViewModels"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:views="clr-namespace:Redball.UI.Views"
        Title="Redball" Height="780" Width="1100"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True"
        Style="{DynamicResource ModernWindow}"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource ForegroundBrush}"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="False">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="8"
                            CornerRadius="16"
                            GlassFrameThickness="1"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Add this resource definition if it does not already exist in your merged dictionaries or app resources -->
        <SolidColorBrush x:Key="ForegroundSecondaryBrush" Color="#99000000"/>
    </Window.Resources>

    <Border Margin="8"
            CornerRadius="18"
            Background="{DynamicResource BackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Color="#55000000" Opacity="0.45"/>
        </Border.Effect>

    <Grid ClipToBounds="True">
        <!-- Tray Icon (primary UI for v3.0) -->
        <tb:TaskbarIcon x:Name="TrayIcon"
                       LeftClickCommand="{Binding ShowWindowCommand}"
                       DoubleClickCommand="{Binding ShowWindowCommand}"
                       Visibility="Visible">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu Style="{DynamicResource ModernContextMenu}">
                    <!-- Status Header -->
                    <MenuItem Style="{StaticResource StatusMenuItem}">
                        <MenuItem.Header>
                            <StackPanel>
                                <TextBlock Text="Redball" FontWeight="Bold"/>
                                <TextBlock Text="{Binding StatusText}" FontSize="12" Opacity="0.8"/>
                            </StackPanel>
                        </MenuItem.Header>
                    </MenuItem>
                    <Separator/>

                    <!-- Toggle Action -->
                    <MenuItem Header="Pause Keep-Awake" Command="{Binding PauseKeepAwakeCommand}">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xE769;" FontFamily="Segoe Fluent Icons" FontSize="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator/>

                    <!-- Quick Settings -->
                    <MenuItem Header="Prevent Display Sleep" IsCheckable="True" IsChecked="{Binding PreventDisplaySleep, Mode=OneWay}" Command="{Binding ToggleDisplaySleepCommand}"/>
                    <MenuItem Header="Use F15 Heartbeat" IsCheckable="True" IsChecked="{Binding UseHeartbeat, Mode=OneWay}" Command="{Binding ToggleHeartbeatCommand}"/>
                    <Separator/>

                    <!-- TypeThing -->
                    <MenuItem Header="TypeThing (Paste as Typing)" Command="{Binding TypeThingCommand}">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xE8D2;" FontFamily="Segoe Fluent Icons" FontSize="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Emergency HID Release" Command="{Binding EmergencyHidReleaseCommand}">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xEA39;" FontFamily="Segoe Fluent Icons" FontSize="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator/>

                    <MenuItem Header="Open Logs" Command="{Binding OpenLogsCommand}">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xE8A5;" FontFamily="Segoe Fluent Icons" FontSize="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator/>

                    <!-- Main Actions -->
                    <MenuItem Header="Mini Widget" Command="{Binding ShowMiniWidgetCommand}">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xE737;" FontFamily="Segoe Fluent Icons" FontSize="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Reset Mini Widget Position" Command="{Binding ResetMiniWidgetPositionCommand}"
                              Visibility="{Binding IsMiniWidgetVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xE72C;" FontFamily="Segoe Fluent Icons" FontSize="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Check for Updates" Command="{Binding CheckForUpdatesCommand}">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xE895;" FontFamily="Segoe Fluent Icons" FontSize="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Settings..." Command="{Binding OpenSettingsCommand}">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xE713;" FontFamily="Segoe Fluent Icons" FontSize="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Exit" Command="{Binding ExitCommand}">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xE7E8;" FontFamily="Segoe Fluent Icons" FontSize="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>

            <tb:TaskbarIcon.TrayToolTip>
                <Grid Margin="12,10">
                    <TextBlock Text="{Binding ElementName=TrayIcon, Path=ToolTipText}" 
                             FontWeight="SemiBold"
                             FontSize="13"/>
                </Grid>
            </tb:TaskbarIcon.TrayToolTip>
        </tb:TaskbarIcon>

        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="68"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    CornerRadius="18,18,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0,0,0">
                        <Border Width="38" Height="38" CornerRadius="12" Background="{DynamicResource AccentBrush}" Margin="0,0,12,0">
                            <TextBlock Text="R" Foreground="White" FontWeight="Bold" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Redball" FontSize="20" FontWeight="Bold"/>
                                <Border Background="{DynamicResource CardBrush}" CornerRadius="10" Margin="10,2,0,0" Padding="8,2,8,2" VerticalAlignment="Center" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                    <TextBlock Text="Desktop Control Center" FontSize="10" Foreground="{DynamicResource ForegroundSecondaryBrush}"/>
                                </Border>
                            </StackPanel>
                            <TextBlock Text="Keep-awake controls, automation, and diagnostics in one place"
                                       FontSize="11.5"
                                       Foreground="{DynamicResource ForegroundSecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="MinimizeWindowButton"
                                Content="—"
                                Click="MinimizeWindowButton_Click"
                                FontSize="16"
                                ToolTipService.ShowDuration="12000"
                                Style="{StaticResource TitleBarButtonStyle}">
                            <Button.ToolTip>
                                <ToolTip Style="{StaticResource AppToolTipStyle}" Content="Minimize Redball to the taskbar."/>
                            </Button.ToolTip>
                        </Button>
                        <Button x:Name="MaximizeWindowButton"
                                Content="□"
                                Click="MaximizeWindowButton_Click"
                                ToolTipService.ShowDuration="12000"
                                Style="{StaticResource TitleBarButtonStyle}">
                            <Button.ToolTip>
                                <ToolTip Style="{StaticResource AppToolTipStyle}" Content="Maximize or restore the Redball window."/>
                            </Button.ToolTip>
                        </Button>
                        <Button x:Name="CloseWindowButton"
                                Content="✕"
                                Click="CloseWindowButton_Click"
                                ToolTipService.ShowDuration="12000"
                                Style="{StaticResource TitleBarCloseButtonStyle}">
                            <Button.ToolTip>
                                <ToolTip Style="{StaticResource AppToolTipStyle}" Content="Hide Redball back to tray mode."/>
                            </Button.ToolTip>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1" Style="{DynamicResource CardStyle}" Margin="24,20,24,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Current Status" FontSize="12" Foreground="{DynamicResource ForegroundSecondaryBrush}"/>
                        <TextBlock Text="{Binding StatusText}" FontSize="20" FontWeight="SemiBold" Margin="0,4,0,0"/>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Content="Pause / Resume"
                            Command="{Binding PauseKeepAwakeCommand}"
                            Style="{DynamicResource PrimaryButton}">
                        <Button.ToolTip>
                            <ToolTip Style="{StaticResource AppToolTipStyle}" Content="Pause or resume the keep-awake engine without leaving the dashboard."/>
                        </Button.ToolTip>
                    </Button>
                </Grid>
            </Border>

            <Grid Grid.Row="2" Margin="24,0,24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{DynamicResource CardStyle}" Margin="0,0,16,0">
                    <StackPanel>
                        <RadioButton x:Name="HomeNavButton" Content="Home" IsChecked="True" Style="{DynamicResource NavRadioButton}" Checked="NavButton_Checked" ToolTipService.ShowDuration="12000" ToolTip="Overview of the main Redball sections and shortcuts."/>
                        <RadioButton x:Name="AnalyticsNavButton" Content="Analytics" Style="{DynamicResource NavRadioButton}" Checked="NavButton_Checked" ToolTipService.ShowDuration="12000" ToolTip="View session counts, usage patterns, and tracked activity."/>
                        <RadioButton x:Name="MetricsNavButton" Content="Product Metrics" Style="{DynamicResource NavRadioButton}" Checked="NavButton_Checked" ToolTipService.ShowDuration="12000" ToolTip="Inspect feature adoption and product usage metrics."/>
                        <RadioButton x:Name="DiagnosticsNavButton" Content="Diagnostics" Style="{DynamicResource NavRadioButton}" Checked="NavButton_Checked" ToolTipService.ShowDuration="12000" ToolTip="Review runtime state, logging paths, and app health."/>
                        <RadioButton x:Name="SettingsNavButton" Content="Settings" Style="{DynamicResource NavRadioButton}" Checked="NavButton_Checked" ToolTipService.ShowDuration="12000" ToolTip="General application settings such as theme, notifications, and logging."/>
                        <RadioButton x:Name="BehaviorNavButton" Content="Behavior" Style="{DynamicResource NavRadioButton}" Checked="NavButton_Checked" ToolTipService.ShowDuration="12000" ToolTip="Control display sleep prevention, heartbeat key, and default run duration."/>
                        <RadioButton x:Name="SmartFeaturesNavButton" Content="Smart Features" Style="{DynamicResource NavRadioButton}" Checked="NavButton_Checked" ToolTipService.ShowDuration="12000" ToolTip="Tune battery, network, idle, presentation, and scheduled behavior."/>
                        <RadioButton x:Name="TypeThingNavButton" Content="TypeThing" Style="{DynamicResource NavRadioButton}" Checked="NavButton_Checked" ToolTipService.ShowDuration="12000" ToolTip="Configure TypeThing hotkeys, speed, and typing behavior."/>
                        <RadioButton x:Name="PomodoroNavButton" Content="Pomodoro" Style="{DynamicResource NavRadioButton}" Checked="NavButton_Checked" ToolTipService.ShowDuration="12000" ToolTip="Pomodoro focus timer with configurable intervals."/>
                        <RadioButton x:Name="UpdatesNavButton" Content="Updates" Style="{DynamicResource NavRadioButton}" Checked="NavButton_Checked" ToolTipService.ShowDuration="12000" ToolTip="Manage update channels and check for new releases."/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{DynamicResource CardStyle}">
                    <Grid>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="4">
                                <views:HomeSectionView x:Name="HomePanel" Visibility="Visible"/>

                                <StackPanel x:Name="AnalyticsPanel" Visibility="Collapsed">
                                    <TextBlock Text="Analytics" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <TextBlock Text="Track how you use Redball over time. View session counts, total usage hours, and which features you use most. You can also export your data as CSV or JSON for your own records." TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource ForegroundSecondaryBrush}" Margin="0,0,0,16"/>
                                    <UniformGrid Columns="3" Margin="0,0,0,16">
                                        <Border Style="{DynamicResource CardStyle}" Margin="0,0,8,8">
                                            <StackPanel>
                                                <TextBlock Text="Total Sessions" FontSize="12" Foreground="{DynamicResource ForegroundSecondaryBrush}"/>
                                                <TextBlock x:Name="AnalyticsSessionsText" FontSize="24" FontWeight="Bold" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{DynamicResource CardStyle}" Margin="8,0,8,8">
                                            <StackPanel>
                                                <TextBlock Text="Usage Time" FontSize="12" Foreground="{DynamicResource ForegroundSecondaryBrush}"/>
                                                <TextBlock x:Name="AnalyticsUsageText" FontSize="24" FontWeight="Bold" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{DynamicResource CardStyle}" Margin="8,0,0,8">
                                            <StackPanel>
                                                <TextBlock Text="Tracked Events" FontSize="12" Foreground="{DynamicResource ForegroundSecondaryBrush}"/>
                                                <TextBlock x:Name="AnalyticsEventsText" FontSize="24" FontWeight="Bold" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </UniformGrid>

                                    <Border Style="{DynamicResource CardStyle}" Margin="0,0,0,12">
                                        <StackPanel>
                                            <TextBlock Text="Top Product Areas" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                            <TextBlock x:Name="AnalyticsTopAreasText" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{DynamicResource CardStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Session Trend" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                            <TextBlock x:Name="AnalyticsTrendText" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                        <Button Content="Export CSV" Style="{DynamicResource ModernButton}" Margin="0,0,8,0" Click="AnalyticsExportCsv_Click" ToolTip="Export analytics data as a CSV file for spreadsheet import"/>
                                        <Button Content="Export JSON" Style="{DynamicResource ModernButton}" Margin="0,0,8,0" Click="AnalyticsExportJson_Click" ToolTip="Export analytics data as JSON"/>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel x:Name="MetricsPanel" Visibility="Collapsed">
                                    <TextBlock Text="Product Metrics" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <TextBlock Text="A deeper look at feature adoption and engagement. See which Redball features are being used, how often settings are saved, and overall product health at a glance." TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource ForegroundSecondaryBrush}" Margin="0,0,0,16"/>
                                    <UniformGrid Columns="2" Margin="0,0,0,16">
                                        <Border Style="{DynamicResource CardStyle}" Margin="0,0,8,8">
                                            <StackPanel>
                                                <TextBlock Text="Feature Adoption" FontSize="12" Foreground="{DynamicResource ForegroundSecondaryBrush}"/>
                                                <TextBlock x:Name="MetricsAdoptionText" FontSize="24" FontWeight="Bold" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{DynamicResource CardStyle}" Margin="8,0,0,8">
                                            <StackPanel>
                                                <TextBlock Text="Retention" FontSize="12" Foreground="{DynamicResource ForegroundSecondaryBrush}"/>
                                                <TextBlock x:Name="MetricsRetentionText" FontSize="24" FontWeight="Bold" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </UniformGrid>

                                    <UniformGrid Columns="2" Margin="0,0,0,12">
                                        <Border Style="{DynamicResource CardStyle}" Margin="0,0,8,8">
                                            <StackPanel>
                                                <TextBlock Text="TypeThing" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                                <TextBlock x:Name="MetricsTypeThingText" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{DynamicResource CardStyle}" Margin="8,0,0,8">
                                            <StackPanel>
                                                <TextBlock Text="Settings Saves" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                                <TextBlock x:Name="MetricsSettingsText" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </UniformGrid>

                                    <UniformGrid Columns="2">
                                        <Border Style="{DynamicResource CardStyle}" Margin="0,0,8,8">
                                            <StackPanel>
                                                <TextBlock Text="Updates" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                                <TextBlock x:Name="MetricsUpdatesText" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{DynamicResource CardStyle}" Margin="8,0,0,8">
                                            <StackPanel>
                                                <TextBlock Text="Onboarding" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                                <TextBlock x:Name="MetricsOnboardingText" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </UniformGrid>
                                </StackPanel>

                                <StackPanel x:Name="DiagnosticsPanel" Visibility="Collapsed">
                                    <TextBlock Text="Diagnostics" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <TextBlock Text="Troubleshooting and system health information. Check your current configuration, runtime state, log output, hardware details, and session statistics. Useful if something isn't working as expected." TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource ForegroundSecondaryBrush}" Margin="0,0,0,16"/>
                                    <UniformGrid Columns="2" Margin="0,0,0,12">
                                        <Border Style="{DynamicResource CardStyle}" Margin="0,0,8,8">
                                            <StackPanel>
                                                <TextBlock Text="Configuration" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                                <TextBlock x:Name="DiagnosticsConfigText" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{DynamicResource CardStyle}" Margin="8,0,0,8">
                                            <StackPanel>
                                                <TextBlock Text="Runtime" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                                <TextBlock x:Name="DiagnosticsRuntimeText" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </UniformGrid>

                                    <UniformGrid Columns="2" Margin="0,0,0,12">
                                        <Border Style="{DynamicResource CardStyle}" Margin="0,0,8,8">
                                            <StackPanel>
                                                <TextBlock Text="Logging" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                                <TextBlock x:Name="DiagnosticsLoggingText" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{DynamicResource CardStyle}" Margin="8,0,0,8">
                                            <StackPanel>
                                                <TextBlock Text="Analytics Health" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                                <TextBlock x:Name="DiagnosticsAnalyticsText" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </UniformGrid>

                                    <Border Style="{DynamicResource CardStyle}" Margin="0,0,0,12">
                                        <StackPanel>
                                            <TextBlock Text="Session Statistics" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                            <TextBlock x:Name="SessionStatsText" TextWrapping="Wrap" FontFamily="Consolas" FontSize="12"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{DynamicResource CardStyle}" Margin="0,0,0,12">
                                        <StackPanel>
                                            <TextBlock Text="Hardware" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                            <TextBlock x:Name="DiagnosticsTempText" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{DynamicResource CardStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Recent Log Output" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                            <TextBox x:Name="DiagnosticsRecentLogText"
                                                     Height="220"
                                                     IsReadOnly="True"
                                                     AcceptsReturn="True"
                                                     TextWrapping="Wrap"
                                                     VerticalScrollBarVisibility="Auto"
                                                     HorizontalScrollBarVisibility="Auto"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <StackPanel x:Name="SettingsPanel" Visibility="Collapsed">
                                    <TextBlock Text="Settings" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <TextBlock Text="General application settings. Choose your theme, control notifications, manage configuration profiles, toggle logging, and enable the local web API for remote control from scripts." TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource ForegroundSecondaryBrush}" Margin="0,0,0,16"/>
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="SettingsSearchBox" Grid.Column="0" Style="{DynamicResource ModernTextBox}"
                                                 TextChanged="SettingsSearchBox_TextChanged"
                                                 Tag="Search settings..."
                                                 ToolTip="Type to filter settings by keyword"/>
                                        <Button Grid.Column="1" Content="Undo" Style="{DynamicResource ModernButton}" Margin="8,0,0,0" Click="SettingsUndoButton_Click" ToolTip="Undo the last settings change"/>
                                        <Button Grid.Column="2" Content="Reset" Style="{DynamicResource ModernButton}" Margin="8,0,0,0" Click="SettingsResetButton_Click" ToolTip="Reset all settings to defaults"/>
                                    </Grid>
                                    <Border Style="{DynamicResource CardStyle}" Margin="0,0,0,16">
                                        <StackPanel>
                                            <TextBlock Text="Profiles" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                            <TextBlock Text="Save and load named configuration profiles." FontSize="12" Foreground="{DynamicResource ForegroundSecondaryBrush}" Margin="0,0,0,8"/>
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <ComboBox x:Name="ProfileCombo" Grid.Column="0" Style="{DynamicResource ModernComboBox}" ToolTip="Select a saved profile to load"/>
                                                <Button Grid.Column="1" Content="Load" Style="{DynamicResource ModernButton}" Margin="8,0,0,0" Click="ProfileLoad_Click" ToolTip="Load the selected profile"/>
                                                <Button Grid.Column="2" Content="Save" Style="{DynamicResource PrimaryButton}" Margin="8,0,0,0" Click="ProfileSave_Click" ToolTip="Save current settings as a new profile"/>
                                                <Button Grid.Column="3" Content="Delete" Style="{DynamicResource ModernButton}" Margin="8,0,0,0" Click="ProfileDelete_Click" ToolTip="Delete the selected profile"/>
                                            </Grid>
                                            <TextBlock x:Name="ProfileActiveText" Text="" FontSize="11" Foreground="{DynamicResource ForegroundSecondaryBrush}"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{DynamicResource CardStyle}" Margin="0,0,0,16">
                                        <StackPanel>
                                            <TextBlock Text="Local Web API" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                            <CheckBox x:Name="MainWebApiEnabledCheck" Content="Enable local web API" Style="{DynamicResource ModernCheckBox}" Margin="0,0,0,8" Checked="MainSettingChanged" Unchecked="MainSettingChanged" ToolTip="Expose a local HTTP API on localhost for remote control from scripts or companion apps."/>
                                            <TextBlock x:Name="MainWebApiStatusText" Text="" FontSize="11" Foreground="{DynamicResource ForegroundSecondaryBrush}"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{DynamicResource CardStyle}" Margin="0,0,0,16">
                                        <StackPanel>
                                            <TextBlock Text="General" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                            <TextBlock Text="Theme" FontWeight="Medium" Margin="0,0,0,8"/>
                                            <ComboBox x:Name="MainThemeCombo" Style="{DynamicResource ModernComboBox}" Margin="0,0,0,8" SelectionChanged="MainComboSettingChanged" ToolTipService.ShowDuration="12000" ToolTip="Choose the visual theme for the Redball window.">
                                                <ComboBoxItem Content="System Default"/>
                                                <ComboBoxItem Content="Dark Mode"/>
                                                <ComboBoxItem Content="Light Mode"/>
                                                <ComboBoxItem Content="Midnight Blue"/>
                                                <ComboBoxItem Content="Forest Green"/>
                                                <ComboBoxItem Content="Ocean Blue"/>
                                                <ComboBoxItem Content="Sunset Orange"/>
                                                <ComboBoxItem Content="Royal Purple"/>
                                                <ComboBoxItem Content="Slate Gray"/>
                                                <ComboBoxItem Content="Rose Gold"/>
                                                <ComboBoxItem Content="Cyberpunk"/>
                                                <ComboBoxItem Content="Coffee"/>
                                                <ComboBoxItem Content="Arctic Frost"/>
                                            </ComboBox>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12" ToolTip="Live preview of the current theme colors">
                                                <Border Width="36" Height="20" CornerRadius="4" Background="{DynamicResource BackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,4,0"/>
                                                <Border Width="36" Height="20" CornerRadius="4" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,4,0"/>
                                                <Border Width="36" Height="20" CornerRadius="4" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,4,0"/>
                                                <Border Width="36" Height="20" CornerRadius="4" Background="{DynamicResource AccentBrush}" Margin="0,0,4,0"/>
                                                <Border Width="36" Height="20" CornerRadius="4" Background="{DynamicResource ForegroundBrush}" Margin="0,0,4,0"/>
                                                <TextBlock Text="Theme preview" FontSize="10" Foreground="{DynamicResource ForegroundSecondaryBrush}" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                            </StackPanel>
                                            <CheckBox x:Name="MainMinimizeToTrayCheck" Content="Minimize to tray on start" Style="{DynamicResource ModernCheckBox}" Margin="0,0,0,8" Checked="MainSettingChanged" Unchecked="MainSettingChanged" ToolTipService.ShowDuration="12000" ToolTip="Start Redball minimized so it lives in the tray instead of opening on screen."/>
                                            <CheckBox x:Name="MainStartWithWindowsCheck" Content="Start with Windows" Style="{DynamicResource ModernCheckBox}" Margin="0,0,0,8" Checked="MainSettingChanged" Unchecked="MainSettingChanged" ToolTipService.ShowDuration="12000" ToolTip="Automatically launch Redball when you sign in to Windows."/>
                                            <TextBlock x:Name="MainStartWithWindowsStatusText" Text="Startup status: Disabled" FontSize="12" Foreground="{DynamicResource ForegroundSecondaryBrush}" Margin="24,0,0,8"/>
                                            <CheckBox x:Name="MainShowNotificationsCheck" Content="Show notifications" Style="{DynamicResource ModernCheckBox}" Margin="0,0,0,8" Checked="MainShowNotificationsCheck_Checked" Unchecked="MainShowNotificationsCheck_Unchecked" ToolTipService.ShowDuration="12000" ToolTip="Enable or disable toast notifications from Redball."/>
                                            <CheckBox x:Name="MainSoundNotificationsCheck" Content="Play sound with notifications" Style="{DynamicResource ModernCheckBox}" Margin="0,0,0,8" Checked="MainSettingChanged" Unchecked="MainSettingChanged" ToolTipService.ShowDuration="12000" ToolTip="Play a system sound alongside visual notifications."/>
                                            <TextBlock x:Name="MainNotificationModeLabel" Text="Notification Mode" FontWeight="Medium" Margin="0,8,0,8"/>
                                            <ComboBox x:Name="MainNotificationModeCombo" Style="{DynamicResource ModernComboBox}" Margin="0,0,0,8" SelectionChanged="MainComboSettingChanged" ToolTipService.ShowDuration="12000" ToolTip="Choose how chatty Redball should be when sending notifications.">
                                                <ComboBoxItem Content="All events"/>
                                                <ComboBoxItem Content="Important only"/>
                                                <ComboBoxItem Content="Errors only"/>
                                                <ComboBoxItem Content="Silent"/>
                                            </ComboBox>
                                            <CheckBox x:Name="MainEnableLoggingCheck" Content="Enable logging" Style="{DynamicResource ModernCheckBox}" Margin="0,0,0,8" Checked="MainSettingChanged" Unchecked="MainSettingChanged" ToolTipService.ShowDuration="12000" ToolTip="Turn on detailed logging for troubleshooting. Logs are saved to the file system."/>
                                            <Border Style="{DynamicResource CardStyle}" Margin="0,16,0,0">
                                                <StackPanel>
                                                    <TextBlock Text="Advanced" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                                    <TextBlock Text="Enable experimental features, adjust performance settings, and configure advanced diagnostics." FontSize="12" Foreground="{DynamicResource ForegroundSecondaryBrush}" Margin="0,0,0,8"/>
                                                    <CheckBox x:Name="MainEnableExperimentalCheck" Content="Enable experimental features" Style="{DynamicResource ModernCheckBox}" Margin="0,0,0,8" Checked="MainSettingChanged" Unchecked="MainSettingChanged" ToolTipService.ShowDuration="12000" ToolTip="Turn on access to experimental features that are not yet fully tested."/>
                                                    <CheckBox x:Name="MainForceGpuRenderingCheck" Content="Force GPU rendering" Style="{DynamicResource ModernCheckBox}" Margin="0,0,0,8" Checked="MainSettingChanged" Unchecked="MainSettingChanged" ToolTipService.ShowDuration="12000" ToolTip="Use GPU rendering for UI elements to improve performance, especially on high DPI displays."/>
                                                    <CheckBox x:Name="MainDisableHardwareAccelerationCheck" Content="Disable hardware acceleration" Style="{DynamicResource ModernCheckBox}" Margin="0,0,0,8" Checked="MainSettingChanged" Unchecked="MainSettingChanged" ToolTipService.ShowDuration="12000" ToolTip="Disable hardware acceleration for smoother animations at the cost of higher CPU usage."/>
                                                    <Button Content="Open Logs Folder" Style="{DynamicResource ModernButton}" Margin="0,8,0,0" Click="OpenLogsFolderButton_Click" ToolTip="Open the folder containing Redball log files"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <StackPanel x:Name="BehaviorPanel" Visibility="Collapsed">
                                    <TextBlock Text="Behavior" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <TextBlock Text="Configure display sleep prevention, heartbeat key, and default run duration settings." TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource ForegroundSecondaryBrush}" Margin="0,0,0,16"/>
                                    <Border Style="{DynamicResource CardStyle}">
                                        <TextBlock Text="Behavior settings content placeholder" FontSize="14"/>
                                    </Border>
                                </StackPanel>

                                <StackPanel x:Name="SmartFeaturesPanel" Visibility="Collapsed">
                                    <TextBlock Text="Smart Features" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <TextBlock Text="Tune battery, network, idle, presentation, and scheduled behavior." TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource ForegroundSecondaryBrush}" Margin="0,0,0,16"/>
                                    <Border Style="{DynamicResource CardStyle}">
                                        <TextBlock Text="Smart Features settings content placeholder" FontSize="14"/>
                                    </Border>
                                </StackPanel>

                                <StackPanel x:Name="TypeThingPanel" Visibility="Collapsed">
                                    <TextBlock Text="TypeThing" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <TextBlock Text="Configure TypeThing hotkeys, speed, and typing behavior." TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource ForegroundSecondaryBrush}" Margin="0,0,0,16"/>
                                    
                                    <!-- Clipboard History Section -->
                                    <Border Style="{DynamicResource CardStyle}" Margin="0,0,0,16">
                                        <StackPanel>
                                            <TextBlock Text="Clipboard History" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                            <TextBlock Text="Recently typed clipboard content. Click reveal to view (auto-hides for privacy)." 
                                                       TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource ForegroundSecondaryBrush}" Margin="0,0,0,12"/>
                                            
                                            <!-- Reveal Duration Slider -->
                                            <TextBlock Text="Reveal Duration" FontWeight="Medium" Margin="0,0,0,4"/>
                                            <Slider x:Name="ClipboardRevealDurationSlider" Minimum="1" Maximum="60" Value="10" TickFrequency="1"
                                                   IsSnapToTickEnabled="True" Style="{DynamicResource ModernSlider}" Margin="0,0,0,4"
                                                   ValueChanged="ClipboardRevealDurationSlider_ValueChanged"/>
                                            <TextBlock x:Name="ClipboardRevealDurationText" Text="Reveal for: 10 seconds" FontSize="12" 
                                                      Foreground="{DynamicResource ForegroundSecondaryBrush}" Margin="0,0,0,12"/>
                                            
                                            <!-- History List -->
                                            <ListBox x:Name="TypeThingHistoryList" Height="200" Style="{DynamicResource ModernListBox}">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,4">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            
                                                            <!-- Blurred Text Display -->
                                                            <Border Grid.Column="0" Background="{DynamicResource SurfaceBrush}" CornerRadius="4" Padding="8,4">
                                                                <Grid>
                                                                    <!-- Blurred version (default visible) -->
                                                                    <TextBlock x:Name="BlurredText" Text="{Binding BlurredText}" 
                                                                              Foreground="{DynamicResource ForegroundSecondaryBrush}"
                                                                              FontFamily="Consolas" FontSize="12"
                                                                              Visibility="{Binding IsRevealed, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                                                                    <!-- Clear version (visible when revealed) -->
                                                                    <TextBlock x:Name="ClearText" Text="{Binding DisplayText}" 
                                                                              Foreground="{DynamicResource ForegroundBrush}"
                                                                              FontFamily="Consolas" FontSize="12"
                                                                              Visibility="{Binding IsRevealed, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                                </Grid>
                                                            </Border>
                                                            
                                                            <!-- Reveal Button -->
                                                            <Button Grid.Column="1" x:Name="RevealBtn" Content="&#xE8D1;" 
                                                                   FontFamily="Segoe Fluent Icons" FontSize="12"
                                                                   Style="{DynamicResource IconButtonStyle}" 
                                                                   Width="28" Height="28" Margin="4,0"
                                                                   Click="TypeThingHistoryReveal_Click"
                                                                   Tag="{Binding}"
                                                                   ToolTip="Reveal for 10 seconds"/>
                                                            
                                                            <!-- Retype Button -->
                                                            <Button Grid.Column="2" Content="&#xE8D2;" 
                                                                   FontFamily="Segoe Fluent Icons" FontSize="12"
                                                                   Style="{DynamicResource IconButtonStyle}" 
                                                                   Width="28" Height="28"
                                                                   Click="TypeThingHistoryRetype_Click"
                                                                   Tag="{Binding}"
                                                                   ToolTip="Retype this content"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                            
                                            <!-- Clear History Button -->
                                            <Button Content="Clear History" Style="{DynamicResource ModernButton}" 
                                                   HorizontalAlignment="Right" Margin="0,8,0,0"
                                                   Click="TypeThingHistoryClear_Click"/>
                                        </StackPanel>
                                    </Border>
                                    
                                    <Border Style="{DynamicResource CardStyle}" Margin="0,0,0,16">
                                        <StackPanel>
                                            <TextBlock Text="Templates" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                            <TextBlock Text="Save and reuse frequently typed content." 
                                                       TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource ForegroundSecondaryBrush}" Margin="0,0,0,12"/>
                                            
                                            <!-- Template Selection and Preview -->
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                <ComboBox x:Name="TemplateCombo" Grid.Column="0" 
                                                         Style="{DynamicResource ModernComboBox}" 
                                                         Margin="0,0,8,0"
                                                         SelectionChanged="TemplateCombo_SelectionChanged"/>
                                                
                                                <Button Grid.Column="1" Content="Type" 
                                                       Style="{DynamicResource ModernButton}" 
                                                       Margin="0,0,4,0"
                                                       Click="TemplateType_Click"/>
                                                
                                                <Button Grid.Column="2" Content="Save Current" 
                                                       Style="{DynamicResource ModernButton}" 
                                                       Margin="0,0,4,0"
                                                       Click="TemplateSave_Click"/>
                                                
                                                <Button Grid.Column="3" Content="Delete" 
                                                       Style="{DynamicResource ModernButton}" 
                                                       Click="TemplateDelete_Click"/>
                                            </Grid>
                                            
                                            <!-- Template Preview Area -->
                                            <Border Background="{DynamicResource SurfaceBrush}" 
                                                   CornerRadius="4" 
                                                   Margin="0,12,0,0"
                                                   Padding="8"
                                                   BorderBrush="{DynamicResource BorderBrush}"
                                                   BorderThickness="1">
                                                <StackPanel>
                                                    <TextBlock Text="Template Preview" 
                                                              FontWeight="Medium" 
                                                              FontSize="12"
                                                              Foreground="{DynamicResource ForegroundSecondaryBrush}"
                                                              Margin="0,0,0,4"/>
                                                    <ScrollViewer MaxHeight="100" 
                                                                 VerticalScrollBarVisibility="Auto">
                                                        <TextBlock x:Name="TemplatePreviewText" 
                                                                  Text="Select a template to preview its content..."
                                                                  FontFamily="Consolas"
                                                                  FontSize="11"
                                                                  TextWrapping="Wrap"
                                                                  Foreground="{DynamicResource ForegroundBrush}"/>
                                                    </ScrollViewer>
                                                    <TextBlock x:Name="TemplatePreviewStats" 
                                                              Text=""
                                                              FontSize="10"
                                                              Foreground="{DynamicResource ForegroundSecondaryBrush}"
                                                              Margin="0,4,0,0"
                                                              HorizontalAlignment="Right"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                    
                                    <Border Style="{DynamicResource CardStyle}">
                                        <TextBlock Text="TypeThing settings content placeholder" FontSize="14"/>
                                    </Border>
                                </StackPanel>

                                <StackPanel x:Name="PomodoroPanel" Visibility="Collapsed">
                                    <TextBlock Text="Pomodoro" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <TextBlock Text="Pomodoro focus timer with configurable intervals." TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource ForegroundSecondaryBrush}" Margin="0,0,0,16"/>
                                    <Border Style="{DynamicResource CardStyle}">
                                        <TextBlock Text="Pomodoro settings content placeholder" FontSize="14"/>
                                    </Border>
                                </StackPanel>

                                <StackPanel x:Name="UpdatesPanel" Visibility="Collapsed">
                                    <TextBlock Text="Updates" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <TextBlock Text="Manage update channels and check for new releases." TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource ForegroundSecondaryBrush}" Margin="0,0,0,16"/>
                                    <Border Style="{DynamicResource CardStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Update Settings" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                            <CheckBox x:Name="MainAutoUpdateCheck" Content="Check for updates automatically" Style="{DynamicResource ModernCheckBox}" Margin="0,0,0,8" Checked="MainSettingChanged" Unchecked="MainSettingChanged"/>
                                            <TextBlock x:Name="MainUpdateChannelText" Text="Channel: " FontSize="12" Margin="0,0,0,8"/>
                                            <Button Content="Check Now" Style="{DynamicResource ModernButton}" Click="MainCheckUpdatesButton_Click"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="3" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" CornerRadius="0,0,18,18">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Redball - Keep-awake controls, automation, and diagnostics in one place." FontSize="11" Foreground="{DynamicResource ForegroundSecondaryBrush}" Margin="24,0,0,0" VerticalAlignment="Center"/>
                    <Button Content="Donate ⓘ" Style="{DynamicResource TextButtonStyle}" Command="{Binding DonateCommand}" ToolTip="Support the development of Redball!" HorizontalAlignment="Right" Margin="0,0,24,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
    </Border>
</Window>
