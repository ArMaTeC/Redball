<Window x:Class="Redball.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        xmlns:vm="clr-namespace:Redball.UI.ViewModels"
        Title="Redball" Height="450" Width="600"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Visibility="Collapsed">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <!-- Tray Icon (primary UI for v3.0) -->
        <tb:TaskbarIcon x:Name="TrayIcon"
                       ToolTipText="Redball v3.0"
                       LeftClickCommand="{Binding ToggleActiveCommand}"
                       Visibility="Collapsed">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu Style="{StaticResource ModernContextMenu}">
                    <!-- Status Header -->
                    <MenuItem IsEnabled="False" Style="{StaticResource StatusMenuItem}">
                        <MenuItem.Header>
                            <StackPanel>
                                <TextBlock Text="Redball" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
                                <TextBlock Text="{Binding StatusText}" FontSize="12" Opacity="0.8"/>
                            </StackPanel>
                        </MenuItem.Header>
                    </MenuItem>
                    <Separator/>

                    <!-- Toggle Action -->
                    <MenuItem Header="Pause Keep-Awake" Command="{Binding PauseKeepAwakeCommand}">
                        <MenuItem.Icon>
                            <Ellipse Width="12" Height="12" Fill="{StaticResource AccentBrush}"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator/>

                    <!-- Quick Settings -->
                    <MenuItem Header="Display Sleep" IsCheckable="True" IsChecked="True"/>
                    <MenuItem Header="F15 Heartbeat" IsCheckable="True" IsChecked="True"/>
                    <Separator/>

                    <!-- Main Actions -->
                    <MenuItem Header="Settings..." Command="{Binding OpenSettingsCommand}"/>
                    <MenuItem Header="About Redball" Command="{Binding ShowAboutCommand}"/>
                    <Separator/>
                    <MenuItem Header="Exit" Command="{Binding ExitCommand}"/>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>

        <!-- Hidden Window Content (for accessibility/narrator support) -->
        <Border Style="{StaticResource CardStyle}" Visibility="Collapsed">
            <StackPanel>
                <TextBlock Text="Redball v3.0" FontSize="24" FontWeight="Bold"/>
                <TextBlock Text="Modern WPF UI - Tray Only Mode"/>
                <Button Content="Show Settings" Command="{Binding OpenSettingsCommand}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
