<Window x:Class="Redball.UI.Views.ProductMetricsDashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Product Metrics" 
        Height="650" 
        Width="900"
        MinHeight="550"
        MinWidth="750"
        Background="{DynamicResource WindowBackground}">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" 
                Background="{DynamicResource AccentColor}" 
                Height="70"
                Padding="25,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" 
                           Text="📊 Product Metrics Dashboard" 
                           FontSize="22" 
                           FontWeight="SemiBold"
                           Foreground="White"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1" 
                        x:Name="RefreshButton"
                        Content="🔄 Refresh"
                        Click="RefreshButton_Click"
                        Padding="15,8"
                        Background="White"
                        Foreground="{DynamicResource AccentColor}"
                        FontWeight="SemiBold"/>
            </Grid>
        </Border>
        
        <!-- KPI Cards -->
        <Grid Grid.Row="1" Margin="25,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <Border Grid.Column="0" Style="{DynamicResource CardStyle}" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="Session Activity (7d)"
                               ToolTip="Recent app sessions recorded in the last 7 days, compared with the prior 7-day window."
                               FontSize="11" Opacity="0.6"/>
                    <TextBlock x:Name="ActiveUsersText" Text="0" FontSize="28" FontWeight="Bold" 
                               Foreground="{DynamicResource AccentColor}"/>
                    <TextBlock x:Name="ActiveUsersTrend" Text="↑ 0%" FontSize="12" Opacity="0.7"/>
                </StackPanel>
            </Border>
            
            <Border Grid.Column="1" Style="{DynamicResource CardStyle}" Margin="6,0">
                <StackPanel>
                    <TextBlock Text="Avg Session Duration" FontSize="11" Opacity="0.6"/>
                    <TextBlock x:Name="SessionDurationText" Text="0m" FontSize="28" FontWeight="Bold" 
                               Foreground="{DynamicResource AccentColor}"/>
                    <TextBlock Text="Per session" FontSize="12" Opacity="0.7"/>
                </StackPanel>
            </Border>
            
            <Border Grid.Column="2" Style="{DynamicResource CardStyle}" Margin="6,0">
                <StackPanel>
                    <TextBlock Text="Feature Adoption" FontSize="11" Opacity="0.6"/>
                    <TextBlock x:Name="FeatureAdoptionText" Text="0%" FontSize="28" FontWeight="Bold" 
                               Foreground="{DynamicResource AccentColor}"/>
                    <TextBlock x:Name="FeatureAdoptionTrend" Text="Top: Keep-Awake" FontSize="12" Opacity="0.7"/>
                </StackPanel>
            </Border>
            
            <Border Grid.Column="3" Style="{DynamicResource CardStyle}" Margin="12,0,0,0">
                <StackPanel>
                    <TextBlock Text="Retention Rate" FontSize="11" Opacity="0.6"/>
                    <TextBlock x:Name="RetentionText" Text="0%" FontSize="28" FontWeight="Bold" 
                               Foreground="{DynamicResource AccentColor}"/>
                    <TextBlock x:Name="RetentionTrend" Text="30-day" FontSize="12" Opacity="0.7"/>
                </StackPanel>
            </Border>
        </Grid>
        
        <!-- Charts Section -->
        <Grid Grid.Row="2" Margin="25,0,25,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Feature Usage Chart -->
            <Border Grid.Column="0" Style="{DynamicResource CardStyle}" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Product Area Distribution" 
                               FontSize="14" FontWeight="SemiBold" Margin="0,0,0,15"/>
                    
                    <!-- Simulated Bar Chart -->
                    <StackPanel Grid.Row="1" x:Name="FeatureUsageChart">
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Core Usage" VerticalAlignment="Center"/>
                            <ProgressBar Grid.Column="1" x:Name="KeepAwakeBar" Value="85" Maximum="100" Height="20"/>
                            <TextBlock Grid.Column="2" Text="85%" Margin="5,0,0,0" VerticalAlignment="Center"/>
                        </Grid>
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="TypeThing" VerticalAlignment="Center"/>
                            <ProgressBar Grid.Column="1" x:Name="TypeThingBar" Value="45" Maximum="100" Height="20"/>
                            <TextBlock Grid.Column="2" Text="45%" Margin="5,0,0,0" VerticalAlignment="Center"/>
                        </Grid>
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Onboarding / Settings" VerticalAlignment="Center"/>
                            <ProgressBar Grid.Column="1" x:Name="ScheduleBar" Value="30" Maximum="100" Height="20"/>
                            <TextBlock Grid.Column="2" Text="30%" Margin="5,0,0,0" VerticalAlignment="Center"/>
                        </Grid>
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Diagnostics" VerticalAlignment="Center"/>
                            <ProgressBar Grid.Column="1" x:Name="BatteryBar" Value="25" Maximum="100" Height="20"/>
                            <TextBlock Grid.Column="2" Text="25%" Margin="5,0,0,0" VerticalAlignment="Center"/>
                        </Grid>
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Updates / Insights" VerticalAlignment="Center"/>
                            <ProgressBar Grid.Column="1" x:Name="NetworkBar" Value="15" Maximum="100" Height="20"/>
                            <TextBlock Grid.Column="2" Text="15%" Margin="5,0,0,0" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>
            
            <!-- Cohort Analysis -->
            <Border Grid.Column="1" Style="{DynamicResource CardStyle}" Margin="10,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Journey Outcome Snapshot" 
                               FontSize="14" FontWeight="SemiBold" Margin="0,0,0,15"/>
                    
                    <ItemsControl Grid.Row="1" x:Name="JourneyOutcomesList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Label}" ToolTip="{Binding ToolTip}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding HintText}" FontSize="11" Opacity="0.65" Foreground="{Binding HintForeground}" FontWeight="{Binding HintFontWeight}"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding ValueText}" HorizontalAlignment="Right" Foreground="{Binding ValueForeground}" FontWeight="{Binding ValueFontWeight}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>
        </Grid>
        
        <!-- Footer -->
        <Border Grid.Row="3" 
                Background="{DynamicResource PanelBackground}" 
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="25,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="📤 " FontSize="14"/>
                    <TextBlock>
                        <Hyperlink x:Name="ExportMetricsLink" Click="ExportMetricsLink_Click">
                            Export Report
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>
                
                <TextBlock Grid.Column="1" 
                           x:Name="LastUpdatedText"
                           Text="Last updated: Just now" 
                           FontSize="11" 
                           Opacity="0.5"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
                
                <Button Grid.Column="2" 
                        x:Name="FeedbackButton"
                        Content="📝 Send Feedback" 
                        Click="FeedbackButton_Click"
                        Margin="0,0,10,0"
                        Padding="15,5"/>
                
                <Button Grid.Column="3" 
                        x:Name="CloseButton"
                        Content="Close" 
                        Click="CloseButton_Click"
                        Padding="25,5"
                        Background="{DynamicResource AccentColor}"
                        Foreground="White"/>
            </Grid>
        </Border>
    </Grid>
</Window>


