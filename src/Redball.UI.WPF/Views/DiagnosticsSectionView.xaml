<UserControl x:Class="Redball.UI.Views.DiagnosticsSectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock Text="Diagnostics" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <TextBlock Text="Troubleshooting and system health information. Check your current configuration, runtime state, log output, hardware details, and session statistics." 
                   TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource ForegroundSecondaryBrush}" Margin="0,0,0,16"/>
        
        <UniformGrid Columns="2" Margin="0,0,0,12">
            <Border Style="{DynamicResource CardStyle}" Margin="0,0,8,8">
                <StackPanel>
                    <TextBlock Text="Configuration" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <TextBlock x:Name="DiagnosticsConfigText" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
            <Border Style="{DynamicResource CardStyle}" Margin="8,0,0,8">
                <StackPanel>
                    <TextBlock Text="Runtime" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <TextBlock x:Name="DiagnosticsRuntimeText" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <UniformGrid Columns="2" Margin="0,0,0,12">
            <Border Style="{DynamicResource CardStyle}" Margin="0,0,8,8">
                <StackPanel>
                    <TextBlock Text="Logging" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <TextBlock x:Name="DiagnosticsLoggingText" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
            <Border Style="{DynamicResource CardStyle}" Margin="8,0,0,8">
                <StackPanel>
                    <TextBlock Text="Analytics Health" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <TextBlock x:Name="DiagnosticsAnalyticsText" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border Style="{DynamicResource CardStyle}" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Session Statistics" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                <TextBlock x:Name="SessionStatsText" TextWrapping="Wrap" FontFamily="Consolas" FontSize="12"/>
            </StackPanel>
        </Border>

        <Border Style="{DynamicResource CardStyle}" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Hardware" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                <TextBlock x:Name="DiagnosticsTempText" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <Border Style="{DynamicResource CardStyle}">
            <StackPanel>
                <TextBlock Text="Recent Log Output" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                <TextBox x:Name="DiagnosticsRecentLogText"
                         Height="220"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"/>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
