<Window x:Class="Redball.UI.Views.AnalyticsDashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Redball Analytics" 
        Height="500" 
        Width="600"
        MinHeight="450"
        MinWidth="500"
        Background="{DynamicResource WindowBackground}">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" 
                Background="{DynamicResource AccentColor}" 
                Height="60"
                Padding="20,0">
            <Grid>
                <TextBlock Text="📊 Usage Analytics" 
                           FontSize="20" 
                           FontWeight="SemiBold"
                           Foreground="White"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
        
        <!-- Stats Overview -->
        <Grid Grid.Row="1" Margin="20,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <Border Grid.Column="0" Style="{DynamicResource CardStyle}" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="Total Sessions" 
                               FontSize="12" 
                               Opacity="0.7"/>
                    <TextBlock x:Name="SessionsText" 
                               Text="0" 
                               FontSize="24" 
                               FontWeight="Bold"
                               Foreground="{DynamicResource AccentColor}"/>
                    <TextBlock x:Name="SessionsTrendText"
                               Text="Last 7 days vs prior 7 days"
                               FontSize="11"
                               Opacity="0.7"/>
                </StackPanel>
            </Border>
            
            <Border Grid.Column="1" Style="{DynamicResource CardStyle}" Margin="5,0">
                <StackPanel>
                    <TextBlock Text="Total Usage Time" 
                               FontSize="12" 
                               Opacity="0.7"/>
                    <TextBlock x:Name="UsageTimeText" 
                               Text="0h 0m" 
                               FontSize="24" 
                               FontWeight="Bold"
                               Foreground="{DynamicResource AccentColor}"/>
                    <ItemsControl x:Name="UsageOutcomeList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ValueText}"
                                           FontSize="11"
                                           Opacity="0.9"
                                           Foreground="{Binding ValueForeground}"
                                           FontWeight="{Binding ValueFontWeight}"
                                           TextWrapping="Wrap"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
            
            <Border Grid.Column="2" Style="{DynamicResource CardStyle}" Margin="10,0,0,0">
                <StackPanel>
                    <TextBlock Text="Member Since" 
                               FontSize="12" 
                               Opacity="0.7"/>
                    <TextBlock x:Name="MemberSinceText" 
                               Text="-" 
                               FontSize="16" 
                               FontWeight="Bold"
                               Foreground="{DynamicResource AccentColor}"/>
                    <ItemsControl x:Name="CoverageOutcomeList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ValueText}"
                                           FontSize="11"
                                           Opacity="0.9"
                                           Foreground="{Binding ValueForeground}"
                                           FontWeight="{Binding ValueFontWeight}"
                                           TextWrapping="Wrap"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>
        
        <!-- Top Features -->
        <Border Grid.Row="2" Style="{DynamicResource CardStyle}" Margin="20,0,20,15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <TextBlock Grid.Row="0" 
                           Text="🔥 Most Active Product Areas" 
                           FontSize="16" 
                           FontWeight="SemiBold"
                           Margin="0,0,0,10"/>
                
                <ListView Grid.Row="1" 
                          x:Name="FeaturesList"
                          Background="Transparent"
                          BorderThickness="0">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Name}" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Share}"
                                           Margin="0,0,12,0"
                                           Opacity="0.7"/>
                                <TextBlock Grid.Column="2" 
                                           Text="{Binding Count, StringFormat={}{0}x}" 
                                           Opacity="0.7"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
        
        <!-- Footer Actions -->
        <Border Grid.Row="3" 
                Background="{DynamicResource PanelBackground}" 
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="20,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <CheckBox Grid.Column="0" 
                          x:Name="EnableAnalyticsCheck"
                          Content="Enable usage analytics"
                          Checked="EnableAnalyticsCheck_Checked"
                          Unchecked="EnableAnalyticsCheck_Unchecked"/>
                
                <TextBlock Grid.Column="1" 
                           Text="Data is stored locally only" 
                           FontSize="11" 
                           Opacity="0.5"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
                
                <Button Grid.Column="2" 
                        x:Name="ExportButton"
                        Content="Export Data" 
                        Click="ExportButton_Click"
                        Margin="0,0,10,0"
                        Padding="15,5"/>
                
                <Button Grid.Column="3" 
                        x:Name="CloseButton"
                        Content="Close" 
                        Click="CloseButton_Click"
                        Padding="20,5"
                        Background="{DynamicResource AccentColor}"
                        Foreground="White"/>
            </Grid>
        </Border>
    </Grid>
</Window>
