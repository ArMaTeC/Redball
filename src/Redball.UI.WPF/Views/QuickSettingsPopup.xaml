<UserControl x:Class="Redball.UI.Views.QuickSettingsPopup"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="280">
    <Border Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" ShadowDepth="4" Opacity="0.3" Color="Black"/>
        </Border.Effect>
        <StackPanel Margin="16,14">
            <!-- Status -->
            <TextBlock Text="Redball" FontWeight="SemiBold" FontSize="14" Foreground="{DynamicResource ForegroundBrush}"/>
            <TextBlock x:Name="StatusText" FontSize="11.5" Foreground="{DynamicResource ForegroundSecondaryBrush}" Margin="0,2,0,12"/>

            <!-- Quick toggles -->
            <Button x:Name="ToggleActiveBtn" Content="Pause Keep-Awake" 
                    Style="{DynamicResource ModernButton}" Margin="0,0,0,6" Click="ToggleActive_Click"/>
            <Button x:Name="ToggleDisplayBtn" Content="Display Sleep: Prevented"
                    Style="{DynamicResource ModernButton}" Margin="0,0,0,6" Click="ToggleDisplay_Click"/>
            <Button x:Name="ToggleHeartbeatBtn" Content="Heartbeat: On"
                    Style="{DynamicResource ModernButton}" Margin="0,0,0,10" Click="ToggleHeartbeat_Click"/>

            <TextBlock Text="Quick Session" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
            <WrapPanel Margin="0,0,0,10">
                <Button Content="+15m" Style="{DynamicResource ModernButton}" Margin="0,0,6,6" Click="Quick15m_Click"/>
                <Button Content="+60m" Style="{DynamicResource ModernButton}" Margin="0,0,6,6" Click="Quick60m_Click"/>
                <Button x:Name="QuickCustomBtn" Content="+30m" Style="{DynamicResource ModernButton}" Margin="0,0,0,6" Click="QuickCustom_Click"/>
            </WrapPanel>

            <Separator Background="{DynamicResource BorderBrush}" Margin="0,0,0,10"/>

            <!-- Actions -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Widget" Style="{DynamicResource ModernButton}" Margin="0,0,6,0" Click="OpenWidget_Click"/>
                <Button Content="Updates" Style="{DynamicResource ModernButton}" Margin="0,0,6,0" Click="CheckForUpdates_Click"/>
                <Button Content="Settings" Style="{DynamicResource ModernButton}" Margin="0,0,6,0" Click="OpenSettings_Click"/>
                <Button Content="Exit" Style="{DynamicResource ModernButton}" Click="Exit_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
