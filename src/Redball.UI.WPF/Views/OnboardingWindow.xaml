<Window x:Class="Redball.UI.Views.OnboardingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Welcome to Redball" 
        Height="520" 
        Width="640"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Style="{DynamicResource ModernWindow}"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource ForegroundBrush}">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" 
                Background="{DynamicResource AccentBrush}" 
                Height="80"
                Padding="20,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <Image Grid.Column="0" 
                       Source="/Assets/redball.ico" 
                       Width="48" 
                       Height="48"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
                
                <StackPanel Grid.Column="1" Margin="15,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="Welcome to Redball" 
                               FontSize="24" 
                               FontWeight="SemiBold"
                               Foreground="White"/>
                    <TextBlock Text="Keep your Windows PC awake — intelligently" 
                               FontSize="14"
                               Opacity="0.9"
                               Foreground="White"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Content Area -->
        <Grid Grid.Row="1" Margin="30,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <!-- Left: Feature List -->
            <StackPanel Grid.Column="0" Margin="0,0,20,0">
                <TextBlock Text="Quick Setup" 
                           FontSize="18" 
                           FontWeight="SemiBold"
                           Margin="0,0,0,15"/>
                
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,20"
                           Foreground="{DynamicResource ForegroundBrush}">
                    Redball prevents your computer from sleeping while you work. Here's how to get started:
                </TextBlock>
                
                <!-- Feature Cards -->
                <Border Style="{DynamicResource CardStyle}" Margin="0,5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🔴" FontSize="20" Margin="0,0,10,0"/>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="System Tray Icon" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}"/>
                            <TextBlock Text="Look for the red ball in your system tray. Right-click for options." 
                                       Opacity="0.7" FontSize="12" Foreground="{DynamicResource ForegroundSecondaryBrush}"/>
                        </StackPanel>
                    </Grid>
                </Border>
                
                <Border Style="{DynamicResource CardStyle}" Margin="0,5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="⏱️" FontSize="20" Margin="0,0,10,0"/>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Set a Duration" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}"/>
                            <TextBlock Text="Choose how long to stay awake (15/30/60/120 min or indefinite)." 
                                       Opacity="0.7" FontSize="12" Foreground="{DynamicResource ForegroundSecondaryBrush}"/>
                        </StackPanel>
                    </Grid>
                </Border>
                
                <Border Style="{DynamicResource CardStyle}" Margin="0,5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🔋" FontSize="20" Margin="0,0,10,0"/>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Smart Features" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}"/>
                            <TextBlock Text="Enable battery-aware, network-aware, or idle detection modes." 
                                       Opacity="0.7" FontSize="12" Foreground="{DynamicResource ForegroundSecondaryBrush}"/>
                        </StackPanel>
                    </Grid>
                </Border>
                
                <Border Style="{DynamicResource CardStyle}" Margin="0,5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="⌨️" FontSize="20" Margin="0,0,10,0"/>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Keyboard Shortcuts" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}"/>
                            <TextBlock Text="Space = Toggle, D = Display, H = Heartbeat, I = Indefinite" 
                                       Opacity="0.7" FontSize="12" Foreground="{DynamicResource ForegroundSecondaryBrush}"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>
            
            <!-- Right: Settings Preview -->
            <StackPanel Grid.Column="1" Width="200">
                <TextBlock Text="Default Settings" 
                           FontSize="14" 
                           FontWeight="SemiBold"
                           Margin="0,0,0,10"
                           Foreground="{DynamicResource ForegroundBrush}"/>
                
                <CheckBox x:Name="PreventDisplaySleepCheck" 
                          Content="Keep display awake"
                          IsChecked="True"
                          Margin="0,5"
                          Style="{DynamicResource ModernCheckBox}"/>
                
                <CheckBox x:Name="UseHeartbeatCheck" 
                          Content="F15 heartbeat"
                          IsChecked="True"
                          Margin="0,5"
                          Style="{DynamicResource ModernCheckBox}"/>
                
                <CheckBox x:Name="StartWithWindowsCheck" 
                          Content="Start with Windows"
                          IsChecked="False"
                          Margin="0,5"
                          Style="{DynamicResource ModernCheckBox}"/>
                
                <CheckBox x:Name="BatteryAwareCheck" 
                          Content="Battery-aware mode"
                          IsChecked="False"
                          Margin="0,5"
                          Style="{DynamicResource ModernCheckBox}"/>
                
                <CheckBox x:Name="NetworkAwareCheck" 
                          Content="Network-aware mode"
                          IsChecked="False"
                          Margin="0,5"
                          Style="{DynamicResource ModernCheckBox}"/>
                
                <TextBlock Text="Theme:" Margin="0,15,0,5" Foreground="{DynamicResource ForegroundBrush}"/>
                <ComboBox x:Name="ThemeCombo" SelectedIndex="0" Style="{DynamicResource ModernComboBox}">
                    <ComboBoxItem Content="Dark"/>
                    <ComboBoxItem Content="Light"/>
                    <ComboBoxItem Content="System"/>
                </ComboBox>
            </StackPanel>
        </Grid>
        
        <!-- Footer -->
        <Border Grid.Row="2" 
                Background="{DynamicResource PanelBackground}" 
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="20,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <CheckBox Grid.Column="0" 
                          x:Name="ShowOnStartupCheck"
                          Content="Show this on startup"
                          IsChecked="False"
                          Style="{DynamicResource ModernCheckBox}"/>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="📖 " FontSize="14"/>
                    <TextBlock>
                        <Hyperlink NavigateUri="https://github.com/ArMaTeC/Redball/wiki" 
                                   RequestNavigate="Hyperlink_RequestNavigate">
                            View Documentation
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>
                
                <Button Grid.Column="2" 
                        x:Name="GetStartedButton"
                        Content="Get Started" 
                        Click="GetStartedButton_Click"
                        Padding="20,8"
                        Style="{DynamicResource PrimaryButton}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
